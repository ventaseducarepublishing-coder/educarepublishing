---
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Administración | Educare Publishing</title>
  </head>

  <body>
    <main class="card">
      <a class="brand" href="/">
        <span class="logo">EP</span>
        <span>
          <strong>Educare Publishing</strong>
          <small>Panel de administración</small>
        </span>
      </a>

      <div class="eyebrow">Acceso privado</div>
      <h1>Ingresar al panel</h1>

      <p class="intro">
        Acceso exclusivo para administradores autorizados.
      </p>

      <form id="admin-login-form">
        <label>
          Correo electrónico
          <input
            id="email"
            type="email"
            autocomplete="email"
            placeholder="ventaseducarepublishing@gmail.com"
            required
          />
        </label>

        <label>
          Contraseña
          <input
            id="password"
            type="password"
            autocomplete="current-password"
            required
          />
        </label>

        <button id="submit-button" type="submit">
          Ingresar al panel
        </button>

        <div id="message" class="message" role="status"></div>
      </form>

      <p class="helper">
        <a href="/recuperar-contrasena">Olvidé mi contraseña</a>
      </p>

      <p class="back">
        <a href="/">← Volver a la tienda</a>
      </p>
    </main>

    <script>
      import { supabase } from "../lib/supabase";

      const redirect =
        new URLSearchParams(window.location.search).get("redirect") ||
        "/admin";

      const form =
        document.querySelector<HTMLFormElement>("#admin-login-form");

      const button =
        document.querySelector<HTMLButtonElement>("#submit-button");

      const message =
        document.querySelector<HTMLDivElement>("#message");

      function showMessage(
        text: string,
        type: "error" | "success" | ""
      ) {
        if (!message) return;

        message.textContent = text;
        message.className = "message";

        if (type) {
          message.classList.add(type);
        }
      }

      async function checkExistingSession() {
        try {
          const {
            data: { session },
            error,
          } = await supabase.auth.getSession();

          if (error || !session?.user) {
            return;
          }

          const { data: adminRecord, error: adminError } =
            await supabase
              .from("admin_users")
              .select("user_id")
              .eq("user_id", session.user.id)
              .maybeSingle();

          if (!adminError && adminRecord) {
            window.location.replace(redirect);
          }
        } catch (error) {
          console.error("Error verificando la sesión:", error);
        }
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!button) {
          return;
        }

        const email =
          document
            .querySelector<HTMLInputElement>("#email")
            ?.value.trim() ?? "";

        const password =
          document
            .querySelector<HTMLInputElement>("#password")
            ?.value ?? "";

        if (!email || !password) {
          showMessage(
            "Completa el correo y la contraseña.",
            "error"
          );
          return;
        }

        button.disabled = true;
        button.textContent = "Verificando...";
        showMessage("", "");

        try {
          const { data, error } =
            await supabase.auth.signInWithPassword({
              email,
              password,
            });

          if (error || !data.user) {
            console.error(
              "Error al iniciar sesión:",
              error
            );

            showMessage(
              "No fue posible ingresar. Revisa el correo, la contraseña y la confirmación de la cuenta.",
              "error"
            );

            return;
          }

          const {
            data: adminRecord,
            error: adminError,
          } = await supabase
            .from("admin_users")
            .select("user_id, email")
            .eq("user_id", data.user.id)
            .maybeSingle();

          if (adminError || !adminRecord) {
            console.error(
              "La cuenta no está autorizada:",
              adminError
            );

            await supabase.auth.signOut();

            showMessage(
              "Esta cuenta no tiene permisos de administrador.",
              "error"
            );

            return;
          }

          showMessage(
            "Acceso autorizado. Redirigiendo...",
            "success"
          );

          window.location.replace(redirect);
        } catch (error) {
          console.error(
            "Error inesperado en el acceso:",
            error
          );

          showMessage(
            "Ocurrió un error inesperado. Revisa la consola del navegador.",
            "error"
          );
        } finally {
          button.disabled = false;
          button.textContent = "Ingresar al panel";
        }
      });

      checkExistingSession();
    </script>
  </body>
</html>

<style>
  :root {
    font-family:
      Inter,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;

    color: #17324d;
    background: #eef6f7;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(
        circle at top left,
        rgb(15 125 131 / 16%),
        transparent 34rem
      ),
      linear-gradient(
        135deg,
        #f0faf9,
        #f7fafc 52%,
        #eef4f8
      );
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .card {
    width: min(100%, 560px);
    padding: clamp(1.5rem, 5vw, 2.5rem);
    background: rgb(255 255 255 / 96%);
    border: 1px solid #dbe8ed;
    border-radius: 28px;
    box-shadow:
      0 28px 80px
      rgb(23 50 77 / 14%);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .brand span:last-child {
    display: grid;
    gap: 0.15rem;
  }

  .brand small {
    color: #6c8091;
  }

  .logo {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    color: #ffffff;
    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #17324d
      );
    border-radius: 14px;
    font-weight: 900;
  }

  .eyebrow {
    display: inline-flex;
    padding: 0.4rem 0.75rem;
    color: #0f7d83;
    background: #e5f5f4;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 1rem 0 0.7rem;
    font-family: Georgia, serif;
    font-size: clamp(2.3rem, 7vw, 3.5rem);
    line-height: 1;
  }

  .intro {
    margin: 0;
    color: #62778a;
    line-height: 1.7;
  }

  form {
    display: grid;
    gap: 1rem;
    margin-top: 1.8rem;
  }

  label {
    display: grid;
    gap: 0.5rem;
    font-weight: 800;
  }

  input {
    width: 100%;
    min-height: 52px;
    padding: 0.9rem 1rem;
    border: 1px solid #cbdbe3;
    border-radius: 12px;
    background: #ffffff;
    font: inherit;
  }

  input:focus {
    outline:
      3px solid
      rgb(15 125 131 / 15%);
    border-color: #0f7d83;
  }

  button {
    min-height: 52px;
    padding: 0.9rem 1rem;
    color: #ffffff;
    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #126b71
      );
    border: 0;
    border-radius: 12px;
    box-shadow:
      0 12px 28px
      rgb(15 125 131 / 22%);
    font: inherit;
    font-weight: 900;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.68;
    cursor: wait;
  }

  .message {
    min-height: 24px;
    line-height: 1.5;
  }

  .message.error {
    color: #b42318;
  }

  .message.success {
    color: #087443;
  }

  .helper,
  .back {
    margin: 1.2rem 0 0;
    text-align: center;
  }

  .helper a {
    color: #0f7d83;
    font-weight: 800;
  }

  .back {
    color: #6c8091;
  }
</style>
