---
const product = {
  id: "lactancia_materna",
  title: "Lactancia Materna",
  shortTitle: "Lactancia Materna",
  subtitle:
    "Una guía práctica, cercana y profesional para vivir la lactancia con mayor seguridad, confianza y tranquilidad.",
  price: 50000,
  priceLabel: "$50.000",
  cover: "/portadas/lactancia-materna.png",
  author: "Andrea Carolina Reyes Hernández",
  category: "Maternidad y salud",
  format: "PDF digital",
  access: "Acceso inmediato",
  pages: "104 páginas",
  language: "Español",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: product.title,
  author: {
    "@type": "Person",
    name: product.author,
  },
  bookFormat: "https://schema.org/EBook",
  inLanguage: "es",
  image: `https://educarepublishing.cl${product.cover}`,
  description: product.subtitle,
  offers: {
    "@type": "Offer",
    priceCurrency: "CLP",
    price: product.price,
    availability: "https://schema.org/InStock",
    url: "https://educarepublishing.cl/ebook/lactancia-materna/",
  },
};
