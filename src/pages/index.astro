        <a href="#nosotros">Nosotros</a>
        <a href="#contacto">Contacto</a>
      </nav>

      <div class="account-actions">
        <a id="login-link" class="account-link" href="/login">Ingresar</a>
        <a class="header-button" href="/mi-biblioteca">Mi biblioteca</a>
      </div>
    </header>

    <main>
      <section class="hero" id="inicio">
        <div class="hero-content">
          <span class="eyebrow">EDITORIAL DIGITAL</span>

          <h1>
            Conocimiento que inspira,
            <span>educa y transforma.</span>
          </h1>

          <p>
            Descubre ebooks prácticos sobre salud, educación, cocina y
            desarrollo personal, creados para acompañarte en cada etapa.
          </p>

          <div class="hero-actions">
            <a class="primary-button" href="#ebooks">Explorar ebooks</a>
            <a class="secondary-button" href="/registro">
              Crear cuenta gratis
            </a>
          </div>

          <div class="benefits">
            <span>✓ Compra segura</span>
            <span>✓ Biblioteca personal</span>
            <span>✓ Descarga digital</span>
          </div>
        </div>

        <div class="hero-visual" aria-label="Biblioteca digital">
          <div class="book book-one">
            <span>EDUCARE</span>
            <strong>Salud y bienestar</strong>
          </div>

          <div class="book book-two">
            <span>PUBLISHING</span>
            <strong>Aprender para crecer</strong>
          </div>

          <div class="book book-three">
            <span>COLECCIÓN</span>
            <strong>Cocina y hogar</strong>
          </div>
        </div>
      </section>

      <section class="section" id="ebooks">
        <div class="section-heading">
          <div>
            <span class="eyebrow">NUESTRA COLECCIÓN</span>
            <h2>Ebooks destacados</h2>
          </div>

          <p>
            Material digital pensado para entregar información útil,
            comprensible y aplicable.
          </p>
        </div>

        <div class="ebook-grid">
          {
            ebooks.map((ebook) => (
              <article class="ebook-card">
                <a
                  class="ebook-cover"
                  href={ebook.url}
                  aria-label={`Ver detalles de ${ebook.titulo}`}
                >
                  <img
                    src={ebook.portada}
                    alt={`Portada del ebook ${ebook.titulo}`}
                    loading="lazy"
                    decoding="async"
                  />
                </a>

                <div class="ebook-information">
                  <span class="category">{ebook.categoria}</span>
                  <h3>
                    <a href={ebook.url}>{ebook.titulo}</a>
                  </h3>
                  <p>{ebook.descripcion}</p>

                  <div class="ebook-footer">
                    <strong>{ebook.precio}</strong>

                    <div class="ebook-actions">
                      <a
                        class="details-button"
                        href={ebook.url}
                      >
                        Ver detalles
                      </a>

                      <button
                        type="button"
                        class="buy-button"
                        data-product-id={ebook.id}
