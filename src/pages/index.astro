---
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta
      name="description"
      content="Educare Publishing: ebooks y recursos digitales para aprender, enseñar y crecer."
    />

    <title>Educare Publishing | Ebooks y aprendizaje digital</title>

    <!-- Google Analytics -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-GSFY0MZE56"
    ></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "G-GSFY0MZE56");
    </script>
  </head>

  <body>
    <header class="header" id="site-header">
      <a class="brand" href="/" aria-label="Educare Publishing, inicio">
        <span class="brand-icon">EP</span>
        <span>
          <strong>Educare</strong>
          <small>Publishing</small>
        </span>
      </a>

      <button
        id="menu-toggle"
        class="menu-toggle"
        type="button"
        aria-label="Abrir menú"
        aria-controls="main-nav"
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>

      <nav id="main-nav" aria-label="Navegación principal">
        <a href="#inicio">Inicio</a>
        <a href="#ebooks">Ebooks</a>
        <a href="#categorias">Categorías</a>
        <a href="#nosotros">Nosotros</a>
        <a href="#contacto">Contacto</a>
      </nav>

      <div class="account-actions">
        <a id="login-link" class="account-link" href="/login">Ingresar</a>
        <a class="header-button" href="/mi-biblioteca">Mi biblioteca</a>
      </div>
    </header>

    <main>
      <section class="hero" id="inicio">
        <div class="hero-glow hero-glow-one"></div>
        <div class="hero-glow hero-glow-two"></div>

        <div class="hero-content">
          <span class="eyebrow hero-eyebrow">EDITORIAL DIGITAL CHILENA</span>

          <h1>
            Ebooks para aprender,
            <span>crecer y transformar.</span>
          </h1>

          <p>
            Contenidos prácticos y confiables sobre salud, crianza, educación,
            cocina y desarrollo personal. Compra segura y acceso inmediato desde
            tu biblioteca digital.
          </p>

          <div class="hero-actions">
            <a class="primary-button" href="#ebooks">Explorar colección</a>
            <a class="secondary-button" href="/registro">Crear cuenta gratis</a>
          </div>

          <div class="hero-stats" aria-label="Beneficios de Educare Publishing">
            <div><strong id="ebook-count">—</strong><span>Ebooks publicados</span></div>
            <div><strong>100%</strong><span>Acceso digital</span></div>
            <div><strong>Seguro</strong><span>Pago con Mercado Pago</span></div>
          </div>
        </div>

        <div class="hero-visual" aria-label="Colección digital Educare Publishing">
          <div class="hero-card hero-card-main">
            <span class="hero-card-label">COLECCIÓN EDUCARE</span>
            <strong>Conocimiento práctico para la vida real</strong>
            <small>Salud · Educación · Bienestar</small>
          </div>
          <div class="hero-card hero-card-back hero-card-back-one"></div>
          <div class="hero-card hero-card-back hero-card-back-two"></div>
          <div class="hero-badge">Acceso inmediato</div>
        </div>
      </section>

      <section class="section" id="ebooks">
        <div class="section-heading">
          <div>
            <span class="eyebrow">NUESTRA COLECCIÓN</span>
            <h2>Ebooks destacados</h2>
          </div>

          <p>
            Material digital pensado para entregar información útil,
            comprensible y aplicable.
          </p>
        </div>

        <div class="catalog-toolbar" aria-label="Herramientas del catálogo">
          <label class="catalog-search" for="catalog-search-input">
            <span aria-hidden="true">⌕</span>
            <input
              id="catalog-search-input"
              type="search"
              placeholder="Buscar por título, descripción o categoría..."
              autocomplete="off"
            />
          </label>

          <div id="category-filters" class="category-filters" aria-label="Filtrar por categoría">
            <button class="filter-button is-active" type="button" data-category="all">Todos</button>
          </div>
        </div>

        <div class="ebook-grid" id="ebook-grid">
          <div class="catalog-loading">
            <div class="catalog-loader"></div>
            <strong>Cargando ebooks...</strong>
          </div>
        </div>
      </section>

      <section class="categories" id="categorias">
        <div class="section-heading light">
          <div>
            <span class="eyebrow">EXPLORA</span>
            <h2>Categorías para cada interés</h2>
          </div>
        </div>

        <div class="category-grid">
          <article>
            <span>🏥</span>
            <h3>Salud y cuidados</h3>
            <p>Guías educativas para pacientes, familias y cuidadores.</p>
          </article>

          <article>
            <span>🍲</span>
            <h3>Cocina y bienestar</h3>
            <p>Recetas, alimentación y soluciones prácticas para el hogar.</p>
          </article>

          <article>
            <span>🎓</span>
            <h3>Educación</h3>
            <p>Material para docentes, estudiantes y aprendizaje continuo.</p>
          </article>

          <article>
            <span>📈</span>
            <h3>Desarrollo profesional</h3>
            <p>Herramientas para fortalecer habilidades y competencias.</p>
          </article>
        </div>
      </section>

      <section class="about section" id="nosotros">
        <div class="about-visual">
          <span>Educare</span>
          <strong>Publishing</strong>
          <p>Leer. Aprender. Transformar.</p>
        </div>

        <div class="about-content">
          <span class="eyebrow">SOBRE NOSOTROS</span>
          <h2>Publicamos conocimiento con propósito</h2>

          <p>
            Educare Publishing es una editorial digital orientada a crear
            contenidos educativos de calidad, cercanos y accesibles.
          </p>

          <p>
            Nuestro objetivo es transformar conocimientos especializados en
            herramientas prácticas que ayuden a las personas a aprender,
            enseñar y tomar mejores decisiones.
          </p>

          <a class="primary-button" href="#contacto">Conversemos</a>
        </div>
      </section>

      <section class="contact" id="contacto">
        <div>
          <span class="eyebrow">MANTENTE INFORMADO</span>
          <h2>Recibe noticias y nuevos lanzamientos</h2>
          <p>
            Compra ebooks digitales de forma segura y accede a contenidos
            prácticos creados por Educare Publishing.
          </p>
        </div>

        <a
          class="contact-button"
          href="mailto:ventas@educarepublishing.cl"
        >
          ventas@educarepublishing.cl
        </a>
      </section>
    </main>

    <footer>
      <a class="brand footer-brand" href="/">
        <span class="brand-icon">EP</span>

        <span>
          <strong>Educare</strong>
          <small>Publishing</small>
        </span>
      </a>

      <p>© 2026 Educare Publishing. Todos los derechos reservados.</p>
    </footer>

    <script>
      import { supabase } from "../lib/supabase";

      type CategoryRelation =
        | { name: string }
        | { name: string }[]
        | null;

      type EbookRow = {
        id: string;
        legacy_product_id: string;
        slug: string;
        title: string;
        description: string;
        price: number;
        currency: string;
        cover_url: string | null;
        published: boolean;
        category: CategoryRelation;
      };

      const loginLink =
        document.querySelector<HTMLAnchorElement>("#login-link");
      const ebookGrid =
        document.querySelector<HTMLDivElement>("#ebook-grid");
      const searchInput =
        document.querySelector<HTMLInputElement>("#catalog-search-input");
      const categoryFilters =
        document.querySelector<HTMLDivElement>("#category-filters");
      const ebookCount =
        document.querySelector<HTMLElement>("#ebook-count");
      const menuToggle =
        document.querySelector<HTMLButtonElement>("#menu-toggle");
      const mainNav =
        document.querySelector<HTMLElement>("#main-nav");

      let catalogData: EbookRow[] = [];
      let activeCategory = "all";

      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (session && loginLink) {
        loginLink.textContent = "Cerrar sesión";
        loginLink.href = "#";

        loginLink.addEventListener("click", async (event) => {
          event.preventDefault();
          await supabase.auth.signOut();
          window.location.reload();
        });
      }

      function escapeHtml(value: string) {
        return value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function getCategoryName(category: CategoryRelation) {
        if (!category) return "Sin categoría";
        if (Array.isArray(category)) {
          return category[0]?.name ?? "Sin categoría";
        }
        return category.name;
      }

      function formatPrice(value: number, currency = "CLP") {
        return new Intl.NumberFormat("es-CL", {
          style: "currency",
          currency,
          maximumFractionDigits: 0,
        }).format(Number(value || 0));
      }

      function renderCatalog(ebooks: EbookRow[]) {
        if (!ebookGrid) return;

        if (ebooks.length === 0) {
          ebookGrid.innerHTML = `
            <div class="catalog-empty">
              <strong>Aún no hay ebooks publicados.</strong>
              <p>Muy pronto encontrarás nuevos contenidos digitales.</p>
            </div>
          `;
          return;
        }

        if (ebookCount) ebookCount.textContent = String(ebooks.length);
        renderCategoryFilters(ebooks);

        ebookGrid.innerHTML = ebooks
          .map((ebook) => {
            const title = escapeHtml(ebook.title);
            const description = escapeHtml(
              ebook.description || "Contenido digital de Educare Publishing."
            );
            const category = escapeHtml(getCategoryName(ebook.category));
            const slug = encodeURIComponent(ebook.slug);
            const productId = escapeHtml(
              ebook.legacy_product_id || ebook.slug
            );
            const cover = ebook.cover_url
              ? escapeHtml(ebook.cover_url)
              : "";

            return `
              <article class="ebook-card" data-title="${title.toLowerCase()}" data-description="${description.toLowerCase()}" data-category="${category.toLowerCase()}">
                <a
                  class="ebook-cover"
                  href="/ebook/${slug}/"
                  aria-label="Ver detalles de ${title}"
                >
                  ${
                    cover
                      ? `<img
                          src="${cover}"
                          alt="Portada del ebook ${title}"
                          loading="lazy"
                          decoding="async"
                        />`
                      : `<span class="ebook-cover-placeholder">EP</span>`
                  }
                </a>

                <div class="ebook-information">
                  <span class="category">${category}</span>
                  <h3><a href="/ebook/${slug}/">${title}</a></h3>
                  <p>${description}</p>

                  <div class="ebook-footer">
                    <strong>${formatPrice(
                      Number(ebook.price),
                      ebook.currency || "CLP"
                    )}</strong>

                    <div class="ebook-actions">
                      <a class="details-button" href="/ebook/${slug}/">
                        Ver detalles
                      </a>

                      <button
                        type="button"
                        class="buy-button"
                        data-product-id="${productId}"
                      >
                        Comprar ahora
                      </button>
                    </div>
                  </div>
                </div>
              </article>
            `;
          })
          .join("");

        bindBuyButtons();
      }

      function normalizeText(value: string) {
        return value
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase();
      }

      function renderCategoryFilters(ebooks: EbookRow[]) {
        if (!categoryFilters) return;

        const categories = Array.from(
          new Set(ebooks.map((ebook) => getCategoryName(ebook.category)).filter(Boolean))
        ).sort((a, b) => a.localeCompare(b, "es"));

        categoryFilters.innerHTML = ["Todos", ...categories]
          .map((category, index) => {
            const value = index === 0 ? "all" : normalizeText(category);
            const active = value === activeCategory ? " is-active" : "";
            return `<button class="filter-button${active}" type="button" data-category="${escapeHtml(value)}">${escapeHtml(category)}</button>`;
          })
          .join("");

        categoryFilters.querySelectorAll<HTMLButtonElement>(".filter-button").forEach((button) => {
          button.addEventListener("click", () => {
            activeCategory = button.dataset.category || "all";
            categoryFilters.querySelectorAll(".filter-button").forEach((item) => item.classList.remove("is-active"));
            button.classList.add("is-active");
            applyCatalogFilters();
          });
        });
      }

      function applyCatalogFilters() {
        const query = normalizeText(searchInput?.value.trim() || "");
        const filtered = catalogData.filter((ebook) => {
          const category = normalizeText(getCategoryName(ebook.category));
          const searchable = normalizeText(`${ebook.title} ${ebook.description || ""} ${category}`);
          const matchesSearch = !query || searchable.includes(query);
          const matchesCategory = activeCategory === "all" || category === activeCategory;
          return matchesSearch && matchesCategory;
        });

        renderCatalog(filtered);
      }

      searchInput?.addEventListener("input", applyCatalogFilters);

      menuToggle?.addEventListener("click", () => {
        const open = mainNav?.classList.toggle("is-open") ?? false;
        menuToggle.setAttribute("aria-expanded", String(open));
        menuToggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
      });

      mainNav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mainNav.classList.remove("is-open");
          menuToggle?.setAttribute("aria-expanded", "false");
        });
      });

      async function loadCatalog() {
        if (!ebookGrid) return;

        const { data, error } = await supabase
          .from("ebooks")
          .select(`
            id,
            legacy_product_id,
            slug,
            title,
            description,
            price,
            currency,
            cover_url,
            published,
            category:categories(name)
          `)
          .eq("published", true)
          .order("display_order", { ascending: true })
          .order("published_at", { ascending: false });

        if (error) {
          console.error("No se pudo cargar el catálogo:", error);

          ebookGrid.innerHTML = `
            <div class="catalog-error">
              <strong>No pudimos cargar los ebooks.</strong>
              <p>Recarga la página en unos minutos.</p>
            </div>
          `;
          return;
        }

        catalogData = (data ?? []) as EbookRow[];
        renderCatalog(catalogData);
      }

      function bindBuyButtons() {
        document
          .querySelectorAll<HTMLButtonElement>(".buy-button")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              const productId = button.dataset.productId;

              if (!productId) {
                alert("No se pudo identificar el ebook.");
                return;
              }

              const {
                data: { session: currentSession },
              } = await supabase.auth.getSession();

              if (!currentSession) {
                window.location.href =
                  `/registro?product=${encodeURIComponent(productId)}`;
                return;
              }

              await startCheckout(productId, button);
            });
          });
      }

      async function startCheckout(
        productId: string,
        button?: HTMLButtonElement
      ) {
        const originalText =
          button?.textContent ?? "Comprar ahora";

        if (button) {
          button.disabled = true;
          button.textContent = "Preparando pago...";
        }

        try {
          const {
            data: { session: currentSession },
          } = await supabase.auth.getSession();

          if (!currentSession) {
            window.location.href =
              `/login?product=${encodeURIComponent(productId)}`;
            return;
          }

          const response = await fetch("/api/create-preference", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${currentSession.access_token}`,
            },
            body: JSON.stringify({ productId }),
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(
              data?.error ||
                data?.details?.message ||
                "No se pudo iniciar el pago."
            );
          }

          const checkoutUrl =
            data.init_point || data.sandbox_init_point;

          if (!checkoutUrl) {
            throw new Error(
              "Mercado Pago no devolvió el enlace de pago."
            );
          }

          window.location.href = checkoutUrl;
        } catch (error) {
          console.error("Error al iniciar el pago:", error);

          alert(
            error instanceof Error
              ? error.message
              : "Ocurrió un error al conectar con Mercado Pago."
          );

          if (button) {
            button.disabled = false;
            button.textContent = originalText;
          }
        }
      }

      await loadCatalog();

      const pendingProduct =
        new URLSearchParams(window.location.search).get("buy");

      if (pendingProduct && session) {
        history.replaceState({}, "", "/#ebooks");
        await startCheckout(pendingProduct);
      }
    </script>

    <a
      class="whatsapp-button"
      href="#contacto"
      aria-label="Ir a la sección de contacto"
    >
      Contacto
    </a>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #17324d;
    background: #f8fafc;
    font-synthesis: none;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: #ffffff;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 78px;
    padding: 0 6%;
    background: rgb(255 255 255 / 94%);
    border-bottom: 1px solid #e6edf4;
    backdrop-filter: blur(14px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .account-actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .account-link {
    color: #17324d;
    font-weight: 800;
  }

  .account-link:hover {
    color: #0f7d83;
  }

  .brand-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    color: #ffffff;
    font-weight: 800;
    background: linear-gradient(135deg, #0f7d83, #17456b);
    border-radius: 12px;
  }

  .brand strong,
  .brand small {
    display: block;
    line-height: 1.05;
  }

  .brand strong {
    font-size: 1.08rem;
  }

  .brand small {
    margin-top: 0.18rem;
    color: #60758a;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    color: #40566c;
    font-size: 0.92rem;
    font-weight: 600;
  }

  nav a:hover {
    color: #0f7d83;
  }

  .header-button,
  .primary-button,
  .secondary-button,
  .contact-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.35rem;
    font-weight: 700;
    border-radius: 12px;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .header-button,
  .primary-button {
    color: #ffffff;
    background: #0f7d83;
    box-shadow: 0 12px 30px rgb(15 125 131 / 20%);
  }

  .header-button:hover,
  .primary-button:hover,
  .secondary-button:hover,
  .contact-button:hover {
    transform: translateY(-2px);
  }

  .hero {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    align-items: center;
    gap: 4rem;
    min-height: 690px;
    padding: 5rem 7%;
    overflow: hidden;
    background:
      radial-gradient(circle at 80% 20%, rgb(70 180 177 / 18%), transparent 32%),
      linear-gradient(135deg, #f2fbfa 0%, #f8fafc 48%, #eef4f8 100%);
  }

  .hero-content {
    max-width: 680px;
  }

  .eyebrow {
    display: inline-block;
    color: #0f7d83;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.18em;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 1.5rem;
    color: #17324d;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 6vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  h1 span {
    color: #0f7d83;
  }

  .hero-content > p {
    max-width: 630px;
    color: #526b80;
    font-size: 1.12rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .secondary-button {
    color: #17324d;
    background: #ffffff;
    border: 1px solid #d7e2eb;
  }

  .benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    margin-top: 2rem;
    color: #526b80;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .hero-visual {
    position: relative;
    min-height: 500px;
  }

  .book {
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 245px;
    height: 355px;
    padding: 2rem;
    color: #ffffff;
    border-radius: 8px 20px 20px 8px;
    box-shadow: 0 35px 65px rgb(23 50 77 / 28%);
  }

  .book::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 15px;
    width: 2px;
    content: "";
    background: rgb(255 255 255 / 25%);
  }

  .book span {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.18em;
  }

  .book strong {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    line-height: 1.08;
  }

  .book-one {
    z-index: 3;
    top: 55px;
    left: 30%;
    background: linear-gradient(145deg, #0f7d83, #084f57);
    transform: rotate(-4deg);
  }

  .book-two {
    z-index: 2;
    top: 80px;
    left: 8%;
    background: linear-gradient(145deg, #17324d, #275e83);
    transform: rotate(-13deg);
  }

  .book-three {
    z-index: 1;
    top: 105px;
    left: 52%;
    background: linear-gradient(145deg, #d68a43, #9a5727);
    transform: rotate(8deg);
  }

  .section {
    padding: 6rem 7%;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .section-heading h2,
  .about-content h2,
  .contact h2 {
    margin: 0.55rem 0 0;
    color: #17324d;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
