---
export const prerender = false;
---
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Editar ebook | Educare Publishing</title>
</head>
<body>
  <div id="loading-screen" class="loading-screen">
    <div class="loader"></div>
    <strong>Cargando ebook...</strong>
  </div>

  <div id="app" class="app" hidden>
    <aside class="sidebar">
      <a class="brand" href="/admin">
        <span class="logo">EP</span>
        <span><strong>Educare</strong><small>Administración</small></span>
      </a>
      <nav>
        <a href="/admin"><span>⌂</span> Dashboard</a>
        <a href="/admin/nuevo-ebook"><span>+</span> Nuevo ebook</a>
        <a class="active" href="#"><span>✎</span> Editar ebook</a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-user">
          <span class="avatar">AD</span>
          <span><strong>Administrador</strong><small id="admin-email">Cargando...</small></span>
        </div>
        <button id="logout-button" class="logout-button" type="button">Cerrar sesión</button>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Catálogo editorial</p>
          <h1>Editar ebook</h1>
          <p class="subtitle">Actualiza los datos, la portada o el PDF.</p>
        </div>
        <a class="secondary-button" href="/admin">← Volver al dashboard</a>
      </header>

      <form id="ebook-form" class="form-layout" novalidate>
        <section class="card">
          <div class="section-heading"><span class="step">1</span><div><h2>Información principal</h2><p>Datos comerciales y editoriales.</p></div></div>
          <div class="grid two-columns">
            <label><span>Título *</span><input id="title" required /></label>
            <label><span>Título corto</span><input id="short-title" /></label>
            <label><span>Slug / URL *</span><input id="slug" required /></label>
            <label><span>ID de producto *</span><input id="product-id" required /></label>
          </div>
          <label><span>Subtítulo</span><input id="subtitle" /></label>
          <label><span>Descripción breve *</span><textarea id="description" rows="3" maxlength="300" required></textarea></label>
          <label><span>Descripción completa</span><textarea id="long-description" rows="7"></textarea></label>
        </section>

        <section class="card">
          <div class="section-heading"><span class="step">2</span><div><h2>Clasificación y precio</h2><p>Autor, categoría y datos técnicos.</p></div></div>
          <div class="grid two-columns">
            <label><span>Autor</span><select id="author-id"><option value="">Sin autor asignado</option></select></label>
            <label><span>Categoría</span><select id="category-id"><option value="">Sin categoría</option></select></label>
            <label><span>Precio CLP *</span><input id="price" type="number" min="0" step="1" required /></label>
            <label><span>Número de páginas</span><input id="page-count" type="number" min="1" step="1" /></label>
            <label><span>Formato</span><input id="format" value="PDF" /></label>
            <label><span>Idioma</span><input id="language" value="Español" /></label>
            <label><span>Orden</span><input id="display-order" type="number" min="0" value="0" /></label>
            <label><span>Moneda</span><input id="currency" value="CLP" readonly /></label>
          </div>
          <div class="checkbox-grid">
            <label class="checkbox"><input id="featured" type="checkbox" /><span>Destacar en la tienda</span></label>
            <label class="checkbox"><input id="published" type="checkbox" /><span>Publicado</span></label>
          </div>
        </section>

        <section class="card">
          <div class="section-heading"><span class="step">3</span><div><h2>Archivos</h2><p>Son opcionales. Si no seleccionas archivos nuevos, se conservan los actuales.</p></div></div>
          <div class="uploads-grid">
            <div>
              <label class="upload-box" for="cover-file">
                <strong>Cambiar portada</strong>
                <span>JPG, PNG o WEBP</span>
                <input id="cover-file" type="file" accept="image/jpeg,image/png,image/webp" />
              </label>
              <div id="cover-preview-wrap" class="cover-preview-wrap">
                <img id="cover-preview" alt="Portada actual" />
              </div>
            </div>
            <label class="upload-box" for="pdf-file">
              <strong>Cambiar PDF</strong>
              <span id="pdf-name">Se conservará el PDF actual</span>
              <input id="pdf-file" type="file" accept="application/pdf" />
            </label>
          </div>
        </section>

        <section class="card">
          <div class="section-heading"><span class="step">4</span><div><h2>SEO</h2><p>Información para buscadores.</p></div></div>
          <label><span>Título SEO</span><input id="seo-title" maxlength="70" /></label>
          <label><span>Descripción SEO</span><textarea id="seo-description" rows="3" maxlength="160"></textarea></label>
        </section>

        <section class="submit-card">
          <div>
            <strong>Actualizar ebook</strong>
            <p id="status-message">Revisa los cambios antes de guardar.</p>
            <div id="progress-wrap" class="progress-wrap" hidden>
              <div class="progress-track"><div id="progress-bar" class="progress-bar"></div></div>
              <small id="progress-label">Preparando...</small>
            </div>
          </div>
          <button id="submit-button" class="primary-button" type="submit">Guardar cambios</button>
        </section>
      </form>
    </main>
  </div>

  <script>
    import { supabase } from "../../../lib/supabase";

    const $ = (selector) => document.querySelector(selector);
    const loadingScreen = $("#loading-screen");
    const app = $("#app");
    const adminEmail = $("#admin-email");
    const form = $("#ebook-form");
    const submitButton = $("#submit-button");
    const statusMessage = $("#status-message");
    const progressWrap = $("#progress-wrap");
    const progressBar = $("#progress-bar");
    const progressLabel = $("#progress-label");

    const fields = {
      title: $("#title"), shortTitle: $("#short-title"), slug: $("#slug"),
      productId: $("#product-id"), subtitle: $("#subtitle"),
      description: $("#description"), longDescription: $("#long-description"),
      authorId: $("#author-id"), categoryId: $("#category-id"),
      price: $("#price"), pageCount: $("#page-count"), format: $("#format"),
      language: $("#language"), displayOrder: $("#display-order"),
      currency: $("#currency"), featured: $("#featured"), published: $("#published"),
      seoTitle: $("#seo-title"), seoDescription: $("#seo-description"),
      coverFile: $("#cover-file"), pdfFile: $("#pdf-file"),
      coverPreview: $("#cover-preview"), pdfName: $("#pdf-name")
    };

    let ebookId = "";
    let currentEbook = null;

    function slugify(value) {
      return value.normalize("NFD").replace(/[\u0300-\u036f]/g, "")
        .toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
    }

    function safeName(value) {
      return slugify(value) || `ebook-${Date.now()}`;
    }

    function extension(file) {
      const parts = file.name.split(".");
      return parts.length > 1 ? parts.pop().toLowerCase() : "";
    }

    function setStatus(message, type = "") {
      statusMessage.textContent = message;
      statusMessage.className = type ? `status ${type}` : "status";
    }

    function setProgress(percent, label) {
      progressWrap.hidden = false;
      progressBar.style.width = `${percent}%`;
      progressLabel.textContent = label;
    }

    function getIdFromPath() {
      const parts = window.location.pathname.split("/").filter(Boolean);
      return decodeURIComponent(parts.at(-1) || "");
    }

    function storagePathFromPublicUrl(url) {
      if (!url) return "";
      const marker = "/storage/v1/object/public/portadas/";
      const index = url.indexOf(marker);
      return index >= 0 ? decodeURIComponent(url.slice(index + marker.length)) : "";
    }

    async function verifyAdmin() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session?.user) {
        window.location.href = "/admin/login?redirect=" + encodeURIComponent(window.location.pathname);
        return false;
      }
      const { data, error } = await supabase.from("admin_users")
        .select("user_id,email").eq("user_id", session.user.id).maybeSingle();
      if (error || !data) {
        await supabase.auth.signOut();
        window.location.href = "/admin/login";
        return false;
      }
      adminEmail.textContent = data.email ?? session.user.email ?? "Administrador";
      return true;
    }

    async function loadSelects() {
      const [authors, categories] = await Promise.all([
        supabase.from("authors").select("id,name").order("name"),
        supabase.from("categories").select("id,name").order("name")
      ]);
      for (const item of authors.data ?? []) {
        const option = document.createElement("option");
        option.value = item.id; option.textContent = item.name;
        fields.authorId.appendChild(option);
      }
      for (const item of categories.data ?? []) {
        const option = document.createElement("option");
        option.value = item.id; option.textContent = item.name;
        fields.categoryId.appendChild(option);
      }
    }

    async function loadEbook() {
      const { data, error } = await supabase.from("ebooks").select("*").eq("id", ebookId).maybeSingle();
      if (error || !data) throw new Error("No se encontró el ebook solicitado.");
      currentEbook = data;

      fields.title.value = data.title ?? "";
      fields.shortTitle.value = data.short_title ?? "";
      fields.slug.value = data.slug ?? "";
      fields.productId.value = data.legacy_product_id ?? "";
      fields.subtitle.value = data.subtitle ?? "";
      fields.description.value = data.description ?? "";
      fields.longDescription.value = data.long_description ?? "";
      fields.authorId.value = data.author_id ?? "";
      fields.categoryId.value = data.category_id ?? "";
      fields.price.value = data.price ?? 0;
      fields.pageCount.value = data.page_count ?? "";
      fields.format.value = data.format ?? "PDF";
      fields.language.value = data.language ?? "Español";
      fields.displayOrder.value = data.display_order ?? 0;
      fields.currency.value = data.currency ?? "CLP";
      fields.featured.checked = Boolean(data.featured);
      fields.published.checked = Boolean(data.published);
      fields.seoTitle.value = data.seo_title ?? "";
      fields.seoDescription.value = data.seo_description ?? "";
      if (data.cover_url) fields.coverPreview.src = data.cover_url;
      fields.pdfName.textContent = data.pdf_path ? `PDF actual: ${data.pdf_path.split("/").at(-1)}` : "Sin PDF registrado";
    }

    async function initialize() {
      ebookId = getIdFromPath();
      if (!ebookId) {
        setStatus("Falta el ID del ebook.", "error");
        return;
      }
      if (!(await verifyAdmin())) return;
      try {
        await loadSelects();
        await loadEbook();
        loadingScreen.hidden = true;
        app.hidden = false;
      } catch (error) {
        loadingScreen.innerHTML = `<strong>${error instanceof Error ? error.message : "No se pudo cargar el ebook."}</strong><a href="/admin">Volver al dashboard</a>`;
      }
    }

    fields.slug.addEventListener("input", () => {
      fields.slug.value = slugify(fields.slug.value);
    });

    fields.coverFile.addEventListener("change", () => {
      const file = fields.coverFile.files?.[0];
      if (file) fields.coverPreview.src = URL.createObjectURL(file);
    });

    fields.pdfFile.addEventListener("change", () => {
      const file = fields.pdfFile.files?.[0];
      fields.pdfName.textContent = file ? file.name : "Se conservará el PDF actual";
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus("Completa todos los campos obligatorios.", "error");
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = "Guardando...";
      setStatus("Actualizando ebook...");

      const newCover = fields.coverFile.files?.[0];
      const newPdf = fields.pdfFile.files?.[0];
      let coverUrl = currentEbook.cover_url;
      let pdfPath = currentEbook.pdf_path;
      let uploadedCoverPath = "";
      let uploadedPdfPath = "";

      try {
        const slug = slugify(fields.slug.value);
        const timestamp = Date.now();

        if (newCover) {
          if (!newCover.type.startsWith("image/")) throw new Error("La portada debe ser una imagen.");
          uploadedCoverPath = `${slug}/${timestamp}-portada.${extension(newCover) || "jpg"}`;
          setProgress(20, "Subiendo nueva portada...");
          const { error } = await supabase.storage.from("portadas").upload(uploadedCoverPath, newCover, {
            cacheControl: "3600", upsert: false, contentType: newCover.type
          });
          if (error) throw new Error(`No se pudo subir la portada: ${error.message}`);
          coverUrl = supabase.storage.from("portadas").getPublicUrl(uploadedCoverPath).data.publicUrl;
        }

        if (newPdf) {
          if (newPdf.type !== "application/pdf") throw new Error("El archivo debe ser PDF.");
          uploadedPdfPath = `${slug}/${timestamp}-${safeName(newPdf.name.replace(/\.pdf$/i, ""))}.pdf`;
          setProgress(55, "Subiendo nuevo PDF...");
          const { error } = await supabase.storage.from("ebooks").upload(uploadedPdfPath, newPdf, {
            cacheControl: "3600", upsert: false, contentType: "application/pdf"
          });
          if (error) throw new Error(`No se pudo subir el PDF: ${error.message}`);
          pdfPath = uploadedPdfPath;
        }

        setProgress(85, "Guardando cambios...");
        const published = fields.published.checked;
        const payload = {
          legacy_product_id: fields.productId.value.trim(),
          slug,
          title: fields.title.value.trim(),
          short_title: fields.shortTitle.value.trim() || null,
          subtitle: fields.subtitle.value.trim() || null,
          description: fields.description.value.trim(),
          long_description: fields.longDescription.value.trim() || null,
          author_id: fields.authorId.value || null,
          category_id: fields.categoryId.value || null,
          price: Number(fields.price.value),
          currency: fields.currency.value.trim() || "CLP",
          cover_url: coverUrl,
          pdf_path: pdfPath,
          page_count: fields.pageCount.value ? Number(fields.pageCount.value) : null,
          format: fields.format.value.trim() || "PDF",
          language: fields.language.value.trim() || "Español",
          featured: fields.featured.checked,
          published,
          display_order: Number(fields.displayOrder.value || 0),
          seo_title: fields.seoTitle.value.trim() || null,
          seo_description: fields.seoDescription.value.trim() || null,
          published_at: published ? (currentEbook.published_at || new Date().toISOString()) : null
        };

        const { error } = await supabase.from("ebooks").update(payload).eq("id", ebookId);
        if (error) throw new Error(`No se pudo actualizar el ebook: ${error.message}`);

        if (newCover && currentEbook.cover_url) {
          const oldCoverPath = storagePathFromPublicUrl(currentEbook.cover_url);
          if (oldCoverPath) await supabase.storage.from("portadas").remove([oldCoverPath]);
        }
        if (newPdf && currentEbook.pdf_path) {
          await supabase.storage.from("ebooks").remove([currentEbook.pdf_path]);
        }

        setProgress(100, "Cambios guardados.");
        setStatus("Ebook actualizado. Volviendo al dashboard...", "success");
        setTimeout(() => window.location.href = "/admin", 1200);
      } catch (error) {
        if (uploadedCoverPath) await supabase.storage.from("portadas").remove([uploadedCoverPath]);
        if (uploadedPdfPath) await supabase.storage.from("ebooks").remove([uploadedPdfPath]);
        setStatus(error instanceof Error ? error.message : "Ocurrió un error inesperado.", "error");
        progressWrap.hidden = true;
        submitButton.disabled = false;
        submitButton.textContent = "Guardar cambios";
      }
    });

    $("#logout-button")?.addEventListener("click", async () => {
      await supabase.auth.signOut();
      window.location.href = "/admin/login";
    });

    initialize();
  </script>
</body>
</html>

<style>
  :root{font-family:Inter,system-ui,sans-serif;color:#17324d;background:#f3f7f9}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:#f3f7f9}a{color:inherit;text-decoration:none}button,input,textarea,select{font:inherit}[hidden]{display:none!important}
  .loading-screen{min-height:100vh;display:grid;place-items:center;align-content:center;gap:1rem;color:#527086}.loader{width:44px;height:44px;border:4px solid #d7e7ea;border-top-color:#0f7d83;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}
  .app{min-height:100vh;display:grid;grid-template-columns:270px minmax(0,1fr)}.sidebar{position:sticky;top:0;height:100vh;display:flex;flex-direction:column;padding:1.5rem;color:#fff;background:radial-gradient(circle at top left,rgb(255 255 255 / 10%),transparent 20rem),#17324d}
  .brand{display:flex;align-items:center;gap:.8rem;margin-bottom:2rem}.brand>span:last-child,.admin-user>span:last-child{display:grid;min-width:0}.brand small,.admin-user small{color:#b9cad6}.logo,.avatar{display:grid;place-items:center;flex:0 0 auto;color:#fff;background:linear-gradient(135deg,#1aa0a8,#0f7d83);font-weight:900}.logo{width:46px;height:46px;border-radius:14px}.avatar{width:42px;height:42px;border-radius:50%}
  nav{display:grid;gap:.45rem}nav a{display:flex;align-items:center;gap:.8rem;padding:.85rem 1rem;color:#d9e5ec;border-radius:12px;font-weight:700}nav a:hover,nav a.active{color:#fff;background:rgb(255 255 255 / 10%)}.sidebar-footer{margin-top:auto;display:grid;gap:1rem}.admin-user{display:flex;align-items:center;gap:.75rem}.admin-user small{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.logout-button{padding:.75rem 1rem;color:#fff;background:transparent;border:1px solid rgb(255 255 255 / 22%);border-radius:11px;cursor:pointer}
  .main{min-width:0;padding:clamp(1.2rem,3vw,2.5rem)}.topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;margin-bottom:2rem}.eyebrow{margin:0 0 .35rem;color:#0f7d83;font-size:.76rem;font-weight:900;letter-spacing:.09em;text-transform:uppercase}h1,h2{margin:0;font-family:Georgia,serif;color:#17324d}h1{font-size:clamp(2.7rem,6vw,5rem);line-height:.95}h2{font-size:1.7rem}.subtitle,.section-heading p,.submit-card p{margin:.5rem 0 0;color:#6a7e8e;line-height:1.6}
  .primary-button,.secondary-button{min-height:48px;display:inline-flex;align-items:center;justify-content:center;padding:.75rem 1rem;border-radius:11px;font-weight:900;cursor:pointer}.primary-button{color:#fff;background:#0f7d83;border:0}.primary-button:disabled{opacity:.7}.secondary-button{background:#fff;border:1px solid #d8e4ea}
  .form-layout{display:grid;gap:1.25rem}.card,.submit-card{padding:clamp(1.2rem,3vw,1.8rem);background:#fff;border:1px solid #e0e9ee;border-radius:20px;box-shadow:0 18px 45px rgb(23 50 77 / 6%)}.section-heading{display:flex;gap:1rem;margin-bottom:1.5rem}.step{width:38px;height:38px;display:grid;place-items:center;flex:0 0 auto;color:#0f7d83;background:#e7f5f3;border-radius:12px;font-weight:900}
  .grid{display:grid;gap:1rem}.two-columns{grid-template-columns:repeat(2,minmax(0,1fr))}label{display:grid;gap:.45rem;margin-bottom:1rem;font-weight:800}input,textarea,select{width:100%;padding:.85rem .95rem;color:#17324d;background:#fff;border:1px solid #ccdbe2;border-radius:11px;outline:none}input:focus,textarea:focus,select:focus{border-color:#0f7d83;box-shadow:0 0 0 3px rgb(15 125 131 / 12%)}input[readonly]{background:#f5f8fa}textarea{resize:vertical}
  .checkbox-grid{display:flex;flex-wrap:wrap;gap:1rem}.checkbox{display:flex;align-items:center;gap:.65rem;margin:0;padding:.8rem 1rem;background:#f7fafb;border:1px solid #dfe8ec;border-radius:11px}.checkbox input{width:18px;height:18px;margin:0}
  .uploads-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.upload-box{min-height:160px;display:grid;place-items:center;align-content:center;gap:.45rem;padding:1.2rem;text-align:center;background:#f7fafb;border:2px dashed #c9d9df;border-radius:16px;cursor:pointer}.upload-box input{width:auto;max-width:100%;padding:0;border:0}.cover-preview-wrap{margin-top:1rem;padding:.8rem;background:#f7fafb;border-radius:14px;text-align:center}#cover-preview{width:min(100%,220px);max-height:320px;object-fit:contain;border-radius:10px}
  .submit-card{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;margin-bottom:2rem}.status.success{color:#087443}.status.error{color:#b42318}.progress-wrap{margin-top:.9rem}.progress-track{width:min(100%,480px);height:9px;overflow:hidden;background:#e1ecef;border-radius:999px}.progress-bar{width:0;height:100%;background:#0f7d83;border-radius:inherit;transition:width .25s ease}.progress-wrap small{display:block;margin-top:.45rem;color:#637987}
  @media(max-width:820px){.app{display:block}.sidebar{position:static;height:auto;padding:1rem}.sidebar nav{grid-template-columns:repeat(2,minmax(0,1fr))}.sidebar-footer{margin-top:1.25rem}.topbar,.submit-card{align-items:stretch;flex-direction:column}.two-columns,.uploads-grid{grid-template-columns:1fr}}@media(max-width:560px){.main{padding:1rem}.sidebar nav{grid-template-columns:1fr}h1{font-size:3rem}}
</style>
