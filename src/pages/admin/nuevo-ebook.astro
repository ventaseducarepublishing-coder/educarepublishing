---
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Nuevo ebook | Educare Publishing</title>
</head>

<body>
  <div id="loading-screen" class="loading-screen">
    <div class="loader"></div>
    <strong>Verificando acceso...</strong>
  </div>

  <div id="app" class="app" hidden>
    <aside class="sidebar">
      <a class="brand" href="/admin">
        <span class="logo">EP</span>
        <span>
          <strong>Educare</strong>
          <small>Administración</small>
        </span>
      </a>

      <nav>
        <a href="/admin"><span>⌂</span> Dashboard</a>
        <a class="active" href="/admin/nuevo-ebook"><span>+</span> Nuevo ebook</a>
      </nav>

      <div class="sidebar-footer">
        <div class="admin-user">
          <span class="avatar">AD</span>
          <span>
            <strong>Administrador</strong>
            <small id="admin-email">Cargando...</small>
          </span>
        </div>

        <button id="logout-button" class="logout-button" type="button">
          Cerrar sesión
        </button>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Catálogo editorial</p>
          <h1>Nuevo ebook</h1>
          <p class="subtitle">
            Completa los datos, sube la portada y el PDF, y publica el libro.
          </p>
        </div>

        <a class="secondary-button" href="/admin">← Volver al dashboard</a>
      </header>

      <form id="ebook-form" class="form-layout" novalidate>
        <section class="card">
          <div class="section-heading">
            <span class="step">1</span>
            <div>
              <h2>Información principal</h2>
              <p>Datos comerciales y editoriales del ebook.</p>
            </div>
          </div>

          <div class="grid two-columns">
            <label>
              <span>Título *</span>
              <input id="title" name="title" type="text" required />
            </label>

            <label>
              <span>Título corto</span>
              <input id="short-title" name="short_title" type="text" />
            </label>

            <label>
              <span>Slug / URL *</span>
              <input
                id="slug"
                name="slug"
                type="text"
                placeholder="manual-primeros-auxilios"
                required
              />
              <small>Se usará en /ebook/tu-slug</small>
            </label>

            <label>
              <span>ID de producto *</span>
              <input
                id="product-id"
                name="legacy_product_id"
                type="text"
                placeholder="manual_primeros_auxilios"
                required
              />
              <small>Compatible con Mercado Pago.</small>
            </label>
          </div>

          <label>
            <span>Subtítulo</span>
            <input id="subtitle" name="subtitle" type="text" />
          </label>

          <label>
            <span>Descripción breve *</span>
            <textarea
              id="description"
              name="description"
              rows="3"
              maxlength="300"
              required
            ></textarea>
          </label>

          <label>
            <span>Descripción completa</span>
            <textarea
              id="long-description"
              name="long_description"
              rows="7"
            ></textarea>
          </label>
        </section>

        <section class="card">
          <div class="section-heading">
            <span class="step">2</span>
            <div>
              <h2>Clasificación y precio</h2>
              <p>Define autor, categoría, precio y datos técnicos.</p>
            </div>
          </div>

          <div class="grid two-columns">
            <label>
              <span>Autor</span>
              <select id="author-id" name="author_id">
                <option value="">Sin autor asignado</option>
              </select>
            </label>

            <label>
              <span>Categoría</span>
              <select id="category-id" name="category_id">
                <option value="">Sin categoría</option>
              </select>
            </label>

            <label>
              <span>Precio CLP *</span>
              <input
                id="price"
                name="price"
                type="number"
                min="0"
                step="1"
                required
              />
            </label>

            <label>
              <span>Número de páginas</span>
              <input
                id="page-count"
                name="page_count"
                type="number"
                min="1"
                step="1"
              />
            </label>

            <label>
              <span>Formato</span>
              <input id="format" name="format" type="text" value="PDF" />
            </label>

            <label>
              <span>Idioma</span>
              <input id="language" name="language" type="text" value="Español" />
            </label>

            <label>
              <span>Orden de visualización</span>
              <input
                id="display-order"
                name="display_order"
                type="number"
                min="0"
                step="1"
                value="0"
              />
            </label>

            <label>
              <span>Moneda</span>
              <input id="currency" name="currency" type="text" value="CLP" readonly />
            </label>
          </div>

          <div class="checkbox-grid">
            <label class="checkbox">
              <input id="featured" name="featured" type="checkbox" />
              <span>Destacar en la tienda</span>
            </label>

            <label class="checkbox">
              <input id="published" name="published" type="checkbox" checked />
              <span>Publicar inmediatamente</span>
            </label>
          </div>
        </section>

        <section class="card">
          <div class="section-heading">
            <span class="step">3</span>
            <div>
              <h2>Archivos</h2>
              <p>Sube una portada y el PDF protegido del ebook.</p>
            </div>
          </div>

          <div class="uploads-grid">
            <div>
              <label class="upload-box" for="cover-file">
                <strong>Portada *</strong>
                <span>JPG, PNG o WEBP</span>
                <input
                  id="cover-file"
                  type="file"
                  accept="image/jpeg,image/png,image/webp"
                  required
                />
              </label>

              <div id="cover-preview-wrap" class="cover-preview-wrap" hidden>
                <img id="cover-preview" alt="Vista previa de la portada" />
              </div>
            </div>

            <label class="upload-box" for="pdf-file">
              <strong>Archivo PDF *</strong>
              <span id="pdf-name">Selecciona el ebook</span>
              <input
                id="pdf-file"
                type="file"
                accept="application/pdf"
                required
              />
            </label>
          </div>
        </section>

        <section class="card">
          <div class="section-heading">
            <span class="step">4</span>
            <div>
              <h2>SEO</h2>
              <p>Información para buscadores y redes sociales.</p>
            </div>
          </div>

          <label>
            <span>Título SEO</span>
            <input id="seo-title" name="seo_title" type="text" maxlength="70" />
          </label>

          <label>
            <span>Descripción SEO</span>
            <textarea
              id="seo-description"
              name="seo_description"
              rows="3"
              maxlength="160"
            ></textarea>
          </label>
        </section>

        <section class="submit-card">
          <div>
            <strong>Guardar ebook</strong>
            <p id="status-message">
              Revisa los campos antes de continuar.
            </p>

            <div id="progress-wrap" class="progress-wrap" hidden>
              <div class="progress-track">
                <div id="progress-bar" class="progress-bar"></div>
              </div>
              <small id="progress-label">Preparando...</small>
            </div>
          </div>

          <button id="submit-button" class="primary-button" type="submit">
            Guardar y continuar
          </button>
        </section>
      </form>
    </main>
  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const loadingScreen = document.querySelector("#loading-screen");
    const app = document.querySelector("#app");
    const adminEmail = document.querySelector("#admin-email");
    const form = document.querySelector("#ebook-form");
    const submitButton = document.querySelector("#submit-button");
    const statusMessage = document.querySelector("#status-message");
    const progressWrap = document.querySelector("#progress-wrap");
    const progressBar = document.querySelector("#progress-bar");
    const progressLabel = document.querySelector("#progress-label");

    const titleInput = document.querySelector("#title");
    const shortTitleInput = document.querySelector("#short-title");
    const slugInput = document.querySelector("#slug");
    const productIdInput = document.querySelector("#product-id");
    const descriptionInput = document.querySelector("#description");
    const longDescriptionInput = document.querySelector("#long-description");
    const subtitleInput = document.querySelector("#subtitle");
    const authorSelect = document.querySelector("#author-id");
    const categorySelect = document.querySelector("#category-id");
    const priceInput = document.querySelector("#price");
    const pageCountInput = document.querySelector("#page-count");
    const formatInput = document.querySelector("#format");
    const languageInput = document.querySelector("#language");
    const displayOrderInput = document.querySelector("#display-order");
    const currencyInput = document.querySelector("#currency");
    const featuredInput = document.querySelector("#featured");
    const publishedInput = document.querySelector("#published");
    const seoTitleInput = document.querySelector("#seo-title");
    const seoDescriptionInput = document.querySelector("#seo-description");
    const coverFileInput = document.querySelector("#cover-file");
    const pdfFileInput = document.querySelector("#pdf-file");
    const coverPreviewWrap = document.querySelector("#cover-preview-wrap");
    const coverPreview = document.querySelector("#cover-preview");
    const pdfName = document.querySelector("#pdf-name");

    let slugEdited = false;
    let productIdEdited = false;

    function slugify(value) {
      return value
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function productIdFromTitle(value) {
      return slugify(value).replaceAll("-", "_");
    }

    function safeFileName(value) {
      return slugify(value) || `ebook-${Date.now()}`;
    }

    function setStatus(message, type = "") {
      statusMessage.textContent = message;
      statusMessage.className = type ? `status ${type}` : "status";
    }

    function setProgress(percent, label) {
      progressWrap.hidden = false;
      progressBar.style.width = `${percent}%`;
      progressLabel.textContent = label;
    }

    function resetProgress() {
      progressWrap.hidden = true;
      progressBar.style.width = "0%";
      progressLabel.textContent = "Preparando...";
    }

    function getFileExtension(file) {
      const parts = file.name.split(".");
      return parts.length > 1 ? parts.pop().toLowerCase() : "";
    }

    async function verifyAdmin() {
      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (!session?.user) {
        window.location.href =
          "/admin/login?redirect=" +
          encodeURIComponent(window.location.pathname);
        return null;
      }

      const { data: adminRecord, error } = await supabase
        .from("admin_users")
        .select("user_id,email")
        .eq("user_id", session.user.id)
        .maybeSingle();

      if (error || !adminRecord) {
        await supabase.auth.signOut();
        window.location.href = "/admin/login";
        return null;
      }

      adminEmail.textContent =
        adminRecord.email ?? session.user.email ?? "Administrador";

      return session.user;
    }

    async function loadSelectData() {
      const [authorsResult, categoriesResult] = await Promise.all([
        supabase.from("authors").select("id,name").order("name"),
        supabase.from("categories").select("id,name").order("name"),
      ]);

      if (!authorsResult.error) {
        for (const author of authorsResult.data ?? []) {
          const option = document.createElement("option");
          option.value = author.id;
          option.textContent = author.name;
          authorSelect.appendChild(option);
        }
      }

      if (!categoriesResult.error) {
        for (const category of categoriesResult.data ?? []) {
          const option = document.createElement("option");
          option.value = category.id;
          option.textContent = category.name;
          categorySelect.appendChild(option);
        }
      }
    }

    async function initializePage() {
      const user = await verifyAdmin();
      if (!user) return;

      await loadSelectData();

      loadingScreen.hidden = true;
      app.hidden = false;
    }

    titleInput.addEventListener("input", () => {
      const value = titleInput.value;

      if (!shortTitleInput.value.trim()) {
        shortTitleInput.value = value;
      }

      if (!slugEdited) {
        slugInput.value = slugify(value);
      }

      if (!productIdEdited) {
        productIdInput.value = productIdFromTitle(value);
      }

      if (!seoTitleInput.value.trim()) {
        seoTitleInput.value = value;
      }
    });

    slugInput.addEventListener("input", () => {
      slugEdited = true;
      slugInput.value = slugify(slugInput.value);
    });

    productIdInput.addEventListener("input", () => {
      productIdEdited = true;
      productIdInput.value = productIdInput.value
        .toLowerCase()
        .replace(/[^a-z0-9_]+/g, "_")
        .replace(/^_+|_+$/g, "");
    });

    coverFileInput.addEventListener("change", () => {
      const file = coverFileInput.files?.[0];

      if (!file) {
        coverPreviewWrap.hidden = true;
        coverPreview.removeAttribute("src");
        return;
      }

      coverPreview.src = URL.createObjectURL(file);
      coverPreviewWrap.hidden = false;
    });

    pdfFileInput.addEventListener("change", () => {
      const file = pdfFileInput.files?.[0];
      pdfName.textContent = file ? file.name : "Selecciona el ebook";
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      resetProgress();

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus("Completa todos los campos obligatorios.", "error");
        return;
      }

      const coverFile = coverFileInput.files?.[0];
      const pdfFile = pdfFileInput.files?.[0];

      if (!coverFile || !pdfFile) {
        setStatus("Debes seleccionar una portada y un archivo PDF.", "error");
        return;
      }

      if (!coverFile.type.startsWith("image/")) {
        setStatus("La portada debe ser una imagen válida.", "error");
        return;
      }

      if (pdfFile.type !== "application/pdf") {
        setStatus("El archivo del ebook debe estar en formato PDF.", "error");
        return;
      }

      const slug = slugify(slugInput.value);

      if (!slug) {
        setStatus("El slug no es válido.", "error");
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = "Guardando...";
      setStatus("Comenzando la carga del ebook...");

      const timestamp = Date.now();
      const coverExtension = getFileExtension(coverFile) || "jpg";
      const coverPath = `${slug}/${timestamp}-portada.${coverExtension}`;
      const pdfPath = `${slug}/${timestamp}-${safeFileName(pdfFile.name.replace(/\.pdf$/i, ""))}.pdf`;

      let uploadedCoverPath = "";
      let uploadedPdfPath = "";

      try {
        setProgress(15, "Subiendo portada...");

        const { error: coverUploadError } = await supabase.storage
          .from("portadas")
          .upload(coverPath, coverFile, {
            cacheControl: "3600",
            upsert: false,
            contentType: coverFile.type,
          });

        if (coverUploadError) {
          throw new Error(`No se pudo subir la portada: ${coverUploadError.message}`);
        }

        uploadedCoverPath = coverPath;

        const { data: publicCoverData } = supabase.storage
          .from("portadas")
          .getPublicUrl(coverPath);

        const coverUrl = publicCoverData.publicUrl;

        setProgress(55, "Subiendo PDF...");

        const { error: pdfUploadError } = await supabase.storage
          .from("ebooks")
          .upload(pdfPath, pdfFile, {
            cacheControl: "3600",
            upsert: false,
            contentType: "application/pdf",
          });

        if (pdfUploadError) {
          throw new Error(`No se pudo subir el PDF: ${pdfUploadError.message}`);
        }

        uploadedPdfPath = pdfPath;

        setProgress(85, "Guardando información...");

        const published = publishedInput.checked;

        const payload = {
          legacy_product_id: productIdInput.value.trim(),
          slug,
          title: titleInput.value.trim(),
          short_title: shortTitleInput.value.trim() || null,
          subtitle: subtitleInput.value.trim() || null,
          description: descriptionInput.value.trim(),
          long_description: longDescriptionInput.value.trim() || null,
          author_id: authorSelect.value || null,
          category_id: categorySelect.value || null,
          price: Number(priceInput.value),
          currency: currencyInput.value.trim() || "CLP",
          cover_url: coverUrl,
          pdf_path: pdfPath,
          page_count: pageCountInput.value
            ? Number(pageCountInput.value)
            : null,
          format: formatInput.value.trim() || "PDF",
          language: languageInput.value.trim() || "Español",
          featured: featuredInput.checked,
          published,
          display_order: Number(displayOrderInput.value || 0),
          seo_title: seoTitleInput.value.trim() || null,
          seo_description: seoDescriptionInput.value.trim() || null,
          published_at: published ? new Date().toISOString() : null,
        };

        const { error: insertError } = await supabase
          .from("ebooks")
          .insert(payload);

        if (insertError) {
          throw new Error(`No se pudo guardar el ebook: ${insertError.message}`);
        }

        setProgress(100, "Ebook guardado correctamente.");
        setStatus("Ebook creado. Volviendo al dashboard...", "success");

        window.setTimeout(() => {
          window.location.href = "/admin";
        }, 1200);
      } catch (error) {
        console.error(error);

        if (uploadedPdfPath) {
          await supabase.storage.from("ebooks").remove([uploadedPdfPath]);
        }

        if (uploadedCoverPath) {
          await supabase.storage.from("portadas").remove([uploadedCoverPath]);
        }

        const message =
          error instanceof Error
            ? error.message
            : "Ocurrió un error inesperado.";

        setStatus(message, "error");
        resetProgress();
        submitButton.disabled = false;
        submitButton.textContent = "Guardar y continuar";
      }
    });

    document
      .querySelector("#logout-button")
      ?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        window.location.href = "/admin/login";
      });

    initializePage();
  </script>
</body>
</html>

<style>
  :root {
    font-family: Inter, system-ui, sans-serif;
    color: #17324d;
    background: #f3f7f9;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: #f3f7f9;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  [hidden] {
    display: none !important;
  }

  .loading-screen {
    min-height: 100vh;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 1rem;
    color: #527086;
  }

  .loader {
    width: 44px;
    height: 44px;
    border: 4px solid #d7e7ea;
    border-top-color: #0f7d83;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .app {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 270px minmax(0, 1fr);
  }

  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    color: #fff;
    background:
      radial-gradient(circle at top left, rgb(255 255 255 / 10%), transparent 20rem),
      #17324d;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 2rem;
  }

  .brand > span:last-child,
  .admin-user > span:last-child {
    display: grid;
    min-width: 0;
  }

  .brand small,
  .admin-user small {
    color: #b9cad6;
  }

  .logo,
  .avatar {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    color: #fff;
    background: linear-gradient(135deg, #1aa0a8, #0f7d83);
    font-weight: 900;
  }

  .logo {
    width: 46px;
    height: 46px;
    border-radius: 14px;
  }

  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
  }

  nav {
    display: grid;
    gap: 0.45rem;
  }

  nav a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.85rem 1rem;
    color: #d9e5ec;
    border-radius: 12px;
    font-weight: 700;
  }

  nav a:hover,
  nav a.active {
    color: #fff;
    background: rgb(255 255 255 / 10%);
  }

  .sidebar-footer {
    margin-top: auto;
    display: grid;
    gap: 1rem;
  }

  .admin-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .admin-user small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .logout-button {
    padding: 0.75rem 1rem;
    color: #fff;
    background: transparent;
    border: 1px solid rgb(255 255 255 / 22%);
    border-radius: 11px;
    cursor: pointer;
  }

  .main {
    min-width: 0;
    padding: clamp(1.2rem, 3vw, 2.5rem);
  }

  .topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    color: #0f7d83;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    margin: 0;
    font-family: Georgia, serif;
    color: #17324d;
  }

  h1 {
    font-size: clamp(2.7rem, 6vw, 5rem);
    line-height: 0.95;
  }

  h2 {
    font-size: 1.7rem;
  }

  .subtitle,
  .section-heading p,
  .submit-card p {
    margin: 0.5rem 0 0;
    color: #6a7e8e;
    line-height: 1.6;
  }

  .primary-button,
  .secondary-button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1rem;
    border-radius: 11px;
    font-weight: 900;
    cursor: pointer;
  }

  .primary-button {
    color: #fff;
    background: #0f7d83;
    border: 0;
  }

  .primary-button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .secondary-button {
    background: #fff;
    border: 1px solid #d8e4ea;
  }

  .form-layout {
    display: grid;
    gap: 1.25rem;
  }

  .card,
  .submit-card {
    padding: clamp(1.2rem, 3vw, 1.8rem);
    background: #fff;
    border: 1px solid #e0e9ee;
    border-radius: 20px;
    box-shadow: 0 18px 45px rgb(23 50 77 / 6%);
  }

  .section-heading {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .step {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    color: #0f7d83;
    background: #e7f5f3;
    border-radius: 12px;
    font-weight: 900;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .two-columns {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  label {
