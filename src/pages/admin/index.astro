<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Dashboard | Educare Publishing</title>
</head>
<body>
  <div id="loading-screen" class="loading-screen"><div class="loader"></div><strong>Verificando acceso...</strong></div>
  <div id="app" class="app" hidden>
    <aside class="sidebar">
      <a class="brand" href="/admin"><span class="logo">EP</span><span><strong>Educare</strong><small>Administración</small></span></a>
      <nav>
        <a class="active" href="/admin"><span>⌂</span> Dashboard</a>
        <a href="#ebooks"><span>▤</span> Ebooks</a>
        <a class="disabled" href="#" aria-disabled="true"><span>◉</span> Ventas</a>
        <a class="disabled" href="#" aria-disabled="true"><span>♙</span> Clientes</a>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-user"><span class="avatar">AD</span><span><strong>Administrador</strong><small id="admin-email">Cargando...</small></span></div>
        <button id="logout-button" class="logout-button" type="button">Cerrar sesión</button>
      </div>
    </aside>
    <main class="main">
      <header class="topbar">
        <div><p class="eyebrow">Panel de administración</p><h1>Dashboard</h1><p class="subtitle">Gestiona el catálogo digital de Educare Publishing.</p></div>
        <div class="top-actions">
          <a class="secondary-button" href="/" target="_blank">Ver tienda</a>
          <a class="primary-button" href="/admin/nuevo-ebook">+ Nuevo ebook</a>
        </div>
      </header>
      <section class="metrics">
        <article class="metric-card"><div class="metric-icon">📚</div><div><span>Total de ebooks</span><strong id="metric-total">—</strong></div></article>
        <article class="metric-card"><div class="metric-icon">✓</div><div><span>Publicados</span><strong id="metric-published">—</strong></div></article>
        <article class="metric-card"><div class="metric-icon">◌</div><div><span>Borradores</span><strong id="metric-drafts">—</strong></div></article>
        <article class="metric-card"><div class="metric-icon">CLP</div><div><span>Valor del catálogo</span><strong id="metric-value">—</strong></div></article>
      </section>
      <section id="ebooks" class="panel">
        <div class="panel-header"><div><p class="eyebrow">Catálogo</p><h2>Ebooks</h2><p>Información obtenida directamente desde Supabase.</p></div><div class="search-box"><span>⌕</span><input id="search-input" type="search" placeholder="Buscar ebook..." /></div></div>
        <div id="status-message" class="status-message"></div>
        <div class="table-wrap"><table><thead><tr><th>Producto</th><th>Categoría</th><th>Precio</th><th>Estado</th><th>Acciones</th></tr></thead><tbody id="ebooks-body"></tbody></table></div>
        <div id="empty-state" class="empty-state" hidden>No se encontraron ebooks.</div>
      </section>
    </main>
  </div>
<script>
  import { supabase } from "../../lib/supabase";
  type EbookRow={id:string;slug:string;title:string;price:number;currency:string;cover_url:string|null;published:boolean;category:{name:string}|{name:string}[]|null};
  const loadingScreen=document.querySelector<HTMLDivElement>("#loading-screen"); const app=document.querySelector<HTMLDivElement>("#app"); const adminEmail=document.querySelector<HTMLElement>("#admin-email"); const body=document.querySelector<HTMLTableSectionElement>("#ebooks-body"); const emptyState=document.querySelector<HTMLDivElement>("#empty-state"); const statusMessage=document.querySelector<HTMLDivElement>("#status-message"); const searchInput=document.querySelector<HTMLInputElement>("#search-input"); const totalMetric=document.querySelector<HTMLElement>("#metric-total"); const publishedMetric=document.querySelector<HTMLElement>("#metric-published"); const draftsMetric=document.querySelector<HTMLElement>("#metric-drafts"); const valueMetric=document.querySelector<HTMLElement>("#metric-value"); let ebooks:EbookRow[]=[];
  const formatPrice=(value:number,currency="CLP")=>new Intl.NumberFormat("es-CL",{style:"currency",currency,maximumFractionDigits:0}).format(value);
  function getCategoryName(category:EbookRow["category"]){if(!category)return"Sin categoría";if(Array.isArray(category))return category[0]?.name??"Sin categoría";return category.name}
  function escapeHtml(value:string){return value.replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;")}
  function updateMetrics(){const published=ebooks.filter(e=>e.published).length;const drafts=ebooks.length-published;const catalogValue=ebooks.reduce((s,e)=>s+Number(e.price||0),0);if(totalMetric)totalMetric.textContent=String(ebooks.length);if(publishedMetric)publishedMetric.textContent=String(published);if(draftsMetric)draftsMetric.textContent=String(drafts);if(valueMetric)valueMetric.textContent=formatPrice(catalogValue)}
  function renderEbooks(filter=""){if(!body||!emptyState)return;const n=filter.trim().toLowerCase();const filtered=ebooks.filter(e=>e.title.toLowerCase().includes(n)||e.slug.toLowerCase().includes(n)||getCategoryName(e.category).toLowerCase().includes(n));body.innerHTML="";emptyState.hidden=filtered.length>0;for(const ebook of filtered){const row=document.createElement("tr");const cover=ebook.cover_url?`<img src="${escapeHtml(ebook.cover_url)}" alt="" />`:`<span class="cover-placeholder">EP</span>`;row.innerHTML=`<td><div class="product-cell"><div class="cover">${cover}</div><div><strong>${escapeHtml(ebook.title)}</strong><small>/ebook/detalle/?slug=${escapeHtml(ebook.slug)}</small></div></div></td><td>${escapeHtml(getCategoryName(ebook.category))}</td><td class="price">${formatPrice(Number(ebook.price),ebook.currency)}</td><td><span class="status ${ebook.published?"published":"draft"}">${ebook.published?"Publicado":"Borrador"}</span></td><td><div class="row-actions"><a class="icon-button" href="/ebook/detalle/?slug=${encodeURIComponent(ebook.slug)}" target="_blank">Ver</a><a class="edit-button" href="/admin/editar-ebook/${encodeURIComponent(ebook.id)}">Editar</a><button class="toggle-button" type="button" data-id="${ebook.id}" data-published="${String(ebook.published)}">${ebook.published?"Despublicar":"Publicar"}</button></div></td>`;body.appendChild(row)}body.querySelectorAll<HTMLButtonElement>(".toggle-button").forEach(button=>button.addEventListener("click",()=>togglePublished(button.dataset.id??"",button.dataset.published==="true",button)))}
  async function togglePublished(id:string,currentValue:boolean,button:HTMLButtonElement){
    if(!id||!statusMessage)return;

    button.disabled=true;
    statusMessage.textContent="Guardando cambio...";
    statusMessage.className="status-message";

    const newValue=!currentValue;

    const{error}=await supabase
      .from("ebooks")
      .update({published:newValue})
      .eq("id",id);

    if(error){
      console.error("Error actualizando ebook:",error);
      statusMessage.textContent=error.message||"No se pudo actualizar el ebook.";
      statusMessage.classList.add("error");
      button.disabled=false;
      return;
    }

    const ebook=ebooks.find(item=>item.id===id);
    if(ebook)ebook.published=newValue;

    updateMetrics();
    renderEbooks(searchInput?.value??"");

    statusMessage.textContent=newValue
      ?"Ebook publicado correctamente."
      :"Ebook guardado como borrador.";

    statusMessage.classList.add("success");
  }
  async function initializeAdmin(){const{data:{session}}=await supabase.auth.getSession();if(!session?.user){window.location.href="/admin/login?redirect="+encodeURIComponent(window.location.pathname);return}const{data:adminRecord,error:adminError}=await supabase.from("admin_users").select("user_id,email").eq("user_id",session.user.id).maybeSingle();if(adminError||!adminRecord){await supabase.auth.signOut();window.location.href="/admin/login";return}if(adminEmail)adminEmail.textContent=adminRecord.email??session.user.email??"Administrador";const{data,error}=await supabase.from("ebooks").select(`id,slug,title,price,currency,cover_url,published,category:categories(name)`).order("display_order",{ascending:true});if(error){if(statusMessage){statusMessage.textContent="No se pudo cargar el catálogo desde Supabase.";statusMessage.classList.add("error")}}else{ebooks=(data??[]) as EbookRow[];updateMetrics();renderEbooks()}if(loadingScreen)loadingScreen.hidden=true;if(app)app.hidden=false}
  searchInput?.addEventListener("input",()=>renderEbooks(searchInput.value));document.querySelector<HTMLButtonElement>("#logout-button")?.addEventListener("click",async()=>{await supabase.auth.signOut();window.location.href="/admin/login"});initializeAdmin();
</script>
</body>
</html>
<style is:global>
:root{font-family:Inter,system-ui,sans-serif;color:#17324d;background:#f3f7f9}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:#f3f7f9}a{color:inherit;text-decoration:none}button,input{font:inherit}[hidden]{display:none!important}.loading-screen{min-height:100vh;display:grid;place-items:center;align-content:center;gap:1rem;color:#527086}.loader{width:44px;height:44px;border:4px solid #d7e7ea;border-top-color:#0f7d83;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.app{min-height:100vh;display:grid;grid-template-columns:270px minmax(0,1fr)}.sidebar{position:sticky;top:0;height:100vh;display:flex;flex-direction:column;padding:1.5rem;color:#fff;background:radial-gradient(circle at top left,rgb(255 255 255 / 10%),transparent 20rem),#17324d}.brand{display:flex;align-items:center;gap:.8rem;margin-bottom:2rem}.brand>span:last-child{display:grid}.brand small,.admin-user small{color:#b9cad6}.logo,.avatar{display:grid;place-items:center;flex:0 0 auto;color:#fff;background:linear-gradient(135deg,#1aa0a8,#0f7d83);font-weight:900}.logo{width:46px;height:46px;border-radius:14px}nav{display:grid;gap:.45rem}nav a{display:flex;align-items:center;gap:.8rem;padding:.85rem 1rem;color:#d9e5ec;border-radius:12px;font-weight:700}nav a:hover,nav a.active{color:#fff;background:rgb(255 255 255 / 10%)}nav a.disabled{opacity:.5;cursor:not-allowed}.sidebar-footer{margin-top:auto;display:grid;gap:1rem}.admin-user{display:flex;align-items:center;gap:.75rem;min-width:0}.admin-user>span:last-child{display:grid;min-width:0}.admin-user small{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.avatar{width:42px;height:42px;border-radius:50%}.logout-button{padding:.75rem 1rem;color:#fff;background:transparent;border:1px solid rgb(255 255 255 / 22%);border-radius:11px;cursor:pointer}.main{min-width:0;padding:clamp(1.2rem,3vw,2.5rem)}.topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;margin-bottom:2rem}.eyebrow{margin:0 0 .35rem;color:#0f7d83;font-size:.76rem;font-weight:900;letter-spacing:.09em;text-transform:uppercase}h1,h2{margin:0;font-family:Georgia,serif;color:#17324d}h1{font-size:clamp(2.4rem,5vw,4rem)}h2{font-size:2rem}.subtitle,.panel-header p{margin:.5rem 0 0;color:#6a7e8e;line-height:1.65}.top-actions{display:flex;gap:.75rem}.primary-button,.secondary-button{min-height:48px;display:inline-flex;align-items:center;justify-content:center;gap:.55rem;padding:.75rem 1rem;border-radius:11px;font-weight:900}.primary-button{color:#fff;background:#0f7d83;border:0}.primary-button small{font-size:.65rem;opacity:.8}.primary-button:disabled{opacity:.72}.secondary-button{background:#fff;border:1px solid #d8e4ea}.metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1rem;margin-bottom:1.5rem}.metric-card{display:flex;align-items:center;gap:1rem;min-width:0;padding:1.25rem;background:#fff;border:1px solid #e0e9ee;border-radius:18px;box-shadow:0 12px 30px rgb(23 50 77 / 5%)}.metric-card>div:last-child{display:grid;gap:.25rem;min-width:0}.metric-card span{color:#718593;font-size:.87rem}.metric-card strong{overflow:hidden;color:#17324d;font-size:1.45rem;text-overflow:ellipsis;white-space:nowrap}.metric-icon{width:48px;height:48px;display:grid;place-items:center;flex:0 0 auto;color:#0f7d83;background:#e9f7f6;border-radius:14px;font-size:.8rem;font-weight:900}.panel{padding:clamp(1rem,3vw,1.5rem);background:#fff;border:1px solid #e0e9ee;border-radius:20px;box-shadow:0 18px 45px rgb(23 50 77 / 6%)}.panel-header{display:flex;align-items:flex-end;justify-content:space-between;gap:1.5rem;margin-bottom:1.25rem}.search-box{min-width:min(100%,300px);display:flex;align-items:center;gap:.55rem;padding:0 .85rem;background:#f8fafb;border:1px solid #dbe6eb;border-radius:11px}.search-box input{width:100%;min-height:44px;background:transparent;border:0;outline:0}.status-message{min-height:24px;margin-bottom:.5rem;color:#667b8b}.status-message.success{color:#087443}.status-message.error{color:#b42318}.table-wrap{overflow-x:auto}table{width:100%;min-width:800px;border-collapse:collapse}th,td{padding:1rem .85rem;border-bottom:1px solid #edf2f5;text-align:left;vertical-align:middle}th{color:#718593;font-size:.77rem;letter-spacing:.05em;text-transform:uppercase}.product-cell{display:flex;align-items:center;gap:.85rem}.product-cell>div:last-child{display:grid;gap:.25rem}.product-cell small{color:#7b8d99}.cover{width:58px;min-width:58px;height:76px;overflow:hidden;flex:0 0 auto;background:#eaf2f5;border-radius:8px}.cover img{display:block;width:100%;height:100%;max-width:58px;max-height:76px;object-fit:cover}.cover-placeholder{width:100%;height:100%;display:grid;place-items:center;color:#fff;background:#0f7d83;font-weight:900}.price{font-weight:900}.status{display:inline-flex;padding:.38rem .65rem;border-radius:999px;font-size:.78rem;font-weight:900}.status.published{color:#087443;background:#e7f7ef}.status.draft{color:#805c00;background:#fff4d6}.row-actions{display:flex;flex-wrap:wrap;gap:.5rem;min-width:250px}.icon-button,.edit-button,.toggle-button{min-height:38px;display:inline-flex;align-items:center;justify-content:center;padding:.55rem .75rem;border-radius:9px;font-size:.83rem;font-weight:800;cursor:pointer}.icon-button{color:#17324d;background:#f5f8fa;border:1px solid #dce6eb}.edit-button{color:#fff;background:#17324d;border:1px solid #17324d}.toggle-button{color:#0f7d83;background:#eaf7f6;border:1px solid #cbe9e7}.empty-state{padding:3rem 1rem;color:#6e8291;text-align:center}@media(max-width:1100px){.metrics{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:820px){.app{display:block}.sidebar{position:static;height:auto;padding:1rem}.sidebar nav{grid-template-columns:repeat(2,minmax(0,1fr))}.sidebar-footer{margin-top:1.25rem}.topbar,.panel-header{align-items:stretch;flex-direction:column}.top-actions,.search-box{width:100%}.top-actions>*{flex:1}}@media(max-width:560px){.main{padding:1rem}.metrics{grid-template-columns:1fr}.top-actions{flex-direction:column}.sidebar nav{grid-template-columns:1fr}}
</style>