---
/*
 * Mi biblioteca — Educare Publishing
 * Versión completa y profesional.
 *
 * Incluye:
 * - Supabase Auth
 * - Compras aprobadas
 * - Buscador y categorías
 * - Lectura online con pestaña de carga
 * - Descarga real mediante Blob
 * - Diseño responsive
 *
 * Los estilos usan is:global porque las tarjetas
 * se crean dinámicamente con JavaScript.
 */
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta
      name="description"
      content="Biblioteca personal de ebooks adquiridos en Educare Publishing."
    />

    <title>Mi biblioteca | Educare Publishing</title>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <span class="logo">EP</span>

          <span class="brand-copy">
            <strong>Educare</strong>
            <small>Publishing</small>
          </span>
        </a>

        <nav
          class="main-nav"
          aria-label="Navegación principal"
        >
          <a href="/">Inicio</a>
          <a href="/#ebooks">Ebooks</a>

          <a
            class="active"
            href="/mi-biblioteca"
          >
            Mi biblioteca
          </a>
        </nav>

        <button
          id="logout"
          class="logout-button"
          type="button"
        >
          Cerrar sesión
        </button>
      </div>
    </header>

    <main class="library-shell">
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">
            MI CUENTA
          </span>

          <h1>Mi biblioteca</h1>

          <p id="welcome">
            Cargando tus ebooks...
          </p>
        </div>

        <div class="library-counter">
          <strong id="book-count">0</strong>
          <span>Ebooks disponibles</span>
        </div>
      </section>

      <section
        class="toolbar"
        aria-label="Herramientas de biblioteca"
      >
        <label class="search-field">
          <span
            class="search-icon"
            aria-hidden="true"
          >
            ⌕
          </span>

          <input
            id="search"
            type="search"
            placeholder="Buscar por título, autor o categoría"
            autocomplete="off"
          />
        </label>

        <label class="category-field">
          <span>Categoría</span>

          <select id="category-filter">
            <option value="all">
              Todas las categorías
            </option>
          </select>
        </label>
      </section>

      <div
        id="general-message"
        class="general-message"
        hidden
      ></div>

      <section
        id="books"
        class="books-grid"
        aria-live="polite"
      ></section>

      <section
        id="no-results"
        class="empty-state"
        hidden
      >
        <span class="empty-icon">🔎</span>

        <h2>No encontramos resultados</h2>

        <p>
          Prueba con otro título, autor o categoría.
        </p>
      </section>

      <section
        id="empty"
        class="empty-state"
        hidden
      >
        <span class="empty-icon">📚</span>

        <h2>
          Aún no tienes ebooks aprobados
        </h2>

        <p>
          Cuando Mercado Pago confirme tu compra,
          el ebook aparecerá automáticamente aquí.
        </p>

        <a
          class="primary-link"
          href="/#ebooks"
        >
          Explorar ebooks
        </a>
      </section>
    </main>

    <script>
      import { supabase } from "../lib/supabase";

      type Relation = { name: string } | { name: string }[] | null;

      type EbookRelation = {
        id: string;
        legacy_product_id: string | null;
        slug: string;
        title: string;
        cover_url: string | null;
        pdf_path: string | null;
        published: boolean;
        category: Relation;
        author: Relation;
      };

      type PurchaseRow = {
        id: string;
        user_id: string;
        ebook_id: string;
        ebook: EbookRelation | EbookRelation[] | null;
      };

      type LibraryItem = {
        purchaseId: string;
        ebookId: string;
        productId: string;
        slug: string;
        title: string;
        coverUrl: string;
        filename: string;
        author: string;
        category: string;
      };

      const welcome = document.querySelector<HTMLElement>("#welcome");
      const books = document.querySelector<HTMLElement>("#books");
      const empty = document.querySelector<HTMLElement>("#empty");
      const noResults = document.querySelector<HTMLElement>("#no-results");
      const generalMessage = document.querySelector<HTMLElement>("#general-message");
      const logoutButton = document.querySelector<HTMLButtonElement>("#logout");
      const searchInput = document.querySelector<HTMLInputElement>("#search");
      const categoryFilter = document.querySelector<HTMLSelectElement>("#category-filter");
      const bookCount = document.querySelector<HTMLElement>("#book-count");

      let libraryItems: LibraryItem[] = [];
      let accessToken = "";

      function relationName(relation: Relation, fallback: string) {
        if (!relation) return fallback;
        if (Array.isArray(relation)) return relation[0]?.name || fallback;
        return relation.name || fallback;
      }

      function normalizeEbook(relation: PurchaseRow["ebook"]): EbookRelation | null {
        if (!relation) return null;
        if (Array.isArray(relation)) return relation[0] || null;
        return relation;
      }

      function filenameFromPath(pdfPath: string | null, slug: string) {
        const filename = pdfPath?.split("/").filter(Boolean).at(-1);
        return filename || `${slug}.pdf`;
      }

      function safeProductId(ebook: EbookRelation) {
        return ebook.legacy_product_id?.trim() || ebook.slug.trim() || ebook.id;
      }

      async function iniciarBiblioteca() {
        try {
          const {
            data: { session },
            error: sessionError,
          } = await supabase.auth.getSession();

          if (sessionError) throw sessionError;

          if (!session?.user) {
            window.location.href =
              `/login?redirect=${encodeURIComponent("/mi-biblioteca")}`;
            return;
          }

          accessToken = session.access_token;

          const displayName =
            session.user.user_metadata?.full_name ||
            session.user.email ||
            "lector";

          if (welcome) {
            welcome.textContent =
              `Hola, ${displayName}. Aquí puedes leer y descargar tus ebooks.`;
          }

          const { data, error } = await supabase
            .from("purchases")
            .select(`
              id,
              user_id,
              ebook_id,
              ebook:ebooks(
                id,
                legacy_product_id,
                slug,
                title,
                cover_url,
                pdf_path,
                published,
                category:categories(name),
                author:authors(name)
              )
            `)
            .eq("user_id", session.user.id);

          if (error) throw error;

          const rows = Array.isArray(data) ? (data as PurchaseRow[]) : [];

          libraryItems = rows
            .map((purchase): LibraryItem | null => {
              const ebook = normalizeEbook(purchase.ebook);
              if (!ebook || !ebook.published) return null;

              return {
                purchaseId: purchase.id,
                ebookId: purchase.ebook_id,
                productId: safeProductId(ebook),
                slug: ebook.slug,
                title: ebook.title,
                coverUrl: ebook.cover_url || "/favicon.svg",
                filename: filenameFromPath(ebook.pdf_path, ebook.slug),
                author: relationName(ebook.author, "Educare Publishing"),
                category: relationName(ebook.category, "General"),
              };
            })
            .filter((item): item is LibraryItem => item !== null);

          if (bookCount) bookCount.textContent = String(libraryItems.length);

          if (!libraryItems.length) {
            if (books) books.innerHTML = "";
            if (empty) empty.hidden = false;
            if (noResults) noResults.hidden = true;
            return;
          }

          if (empty) empty.hidden = true;

          cargarCategorias();
          renderFilteredBooks();
        } catch (error) {
          console.error("Error cargando biblioteca:", error);

          if (welcome) {
            welcome.textContent = "No fue posible cargar tu biblioteca.";
          }

          mostrarMensajeGeneral(
            getErrorMessage(error, "Ocurrió un error inesperado."),
            "error"
          );
        }
      }

      function cargarCategorias() {
        if (!categoryFilter) return;

        const categories = [...new Set(libraryItems.map((item) => item.category))]
          .sort((a, b) => a.localeCompare(b, "es"));

        categoryFilter.innerHTML =
          `<option value="all">Todas las categorías</option>` +
          categories
            .map(
              (category) =>
                `<option value="${escapeHtml(category)}">${escapeHtml(category)}</option>`
            )
            .join("");
      }

      function renderFilteredBooks() {
        const query =
          searchInput?.value.trim().toLocaleLowerCase("es") || "";

        const selectedCategory = categoryFilter?.value || "all";

        const filtered = libraryItems.filter((item) => {
          const searchable =
            `${item.title} ${item.author} ${item.category}`.toLocaleLowerCase("es");

          const matchesSearch = !query || searchable.includes(query);
          const matchesCategory =
            selectedCategory === "all" || item.category === selectedCategory;

          return matchesSearch && matchesCategory;
        });

        if (noResults) {
          noResults.hidden = filtered.length > 0 || libraryItems.length === 0;
        }

        renderBooks(filtered);
      }

      function renderBooks(items: LibraryItem[]) {
        if (!books) return;

        books.innerHTML = items
          .map(
            (item) => `
              <article class="book-card">
                <div class="cover-panel">
                  <img
                    class="book-cover"
                    src="${escapeHtml(item.coverUrl)}"
                    alt="Portada de ${escapeHtml(item.title)}"
                    loading="lazy"
                  />
                </div>

                <div class="book-content">
                  <div class="badges">
                    <span class="status-badge">Compra verificada</span>
                    <span class="category-badge">${escapeHtml(item.category)}</span>
                  </div>

                  <h2>${escapeHtml(item.title)}</h2>

                  <p class="book-author">${escapeHtml(item.author)}</p>

                  <div class="book-info">
                    <span>Estado</span>
                    <strong>Disponible</strong>
                  </div>

                  <div class="book-actions">
                    <button
                      class="read-button"
                      type="button"
                      data-product-id="${escapeHtml(item.productId)}"
                    >
                      Leer online
                    </button>

                    <button
                      class="download-button"
                      type="button"
                      data-product-id="${escapeHtml(item.productId)}"
                      data-filename="${escapeHtml(item.filename)}"
                    >
                      Descargar PDF
                    </button>
                  </div>

                  <p class="action-message" aria-live="polite"></p>
                </div>
              </article>
            `
          )
          .join("");

        conectarBotones();
      }

      function conectarBotones() {
        document
          .querySelectorAll<HTMLButtonElement>(".read-button")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              await abrirOnline(button);
            });
          });

        document
          .querySelectorAll<HTMLButtonElement>(".download-button")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              await descargarArchivo(button);
            });
          });
      }

      async function obtenerEnlace(productId: string) {
        const response = await fetch("/api/download", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${accessToken}`,
          },
          body: JSON.stringify({ productId }),
        });

        let result: { url?: string; error?: string } = {};

        try {
          result = await response.json();
        } catch {
          throw new Error("El servidor entregó una respuesta inválida.");
        }

        if (!response.ok) {
          throw new Error(result.error || "No fue posible autorizar el ebook.");
        }

        if (!result.url) {
          throw new Error("El servidor no entregó el enlace del ebook.");
        }

        return result.url;
      }

      async function abrirOnline(button: HTMLButtonElement) {
        const productId = button.dataset.productId || "";
        const message = obtenerMensaje(button);

        if (!productId || !message) return;

        const originalText = button.textContent || "Leer online";
        const readerWindow = window.open("about:blank", "_blank");

        button.disabled = true;
        button.textContent = "Abriendo...";
        limpiarMensaje(message);

        try {
          if (!readerWindow) {
            throw new Error(
              "El navegador bloqueó la nueva pestaña. Permite ventanas emergentes para este sitio."
            );
          }

          readerWindow.opener = null;
          readerWindow.document.title = "Preparando ebook";
          readerWindow.document.body.innerHTML = `
            <div style="min-height:100vh;display:grid;place-items:center;padding:24px;font-family:Arial,sans-serif;color:#17324d;background:#f4f8fa;">
              <div style="max-width:420px;text-align:center;">
                <div style="width:54px;height:54px;margin:0 auto 18px;border:5px solid #d8e7e8;border-top-color:#0f7d83;border-radius:50%;animation:spin 1s linear infinite;"></div>
                <h2>Preparando tu ebook...</h2>
                <p>Estamos validando tu compra y generando un acceso seguro.</p>
              </div>
              <style>@keyframes spin{to{transform:rotate(360deg);}}</style>
            </div>
          `;

          const url = await obtenerEnlace(productId);
          readerWindow.location.replace(url);

          mostrarMensaje(
            message,
            "Ebook abierto en una nueva pestaña.",
            "success"
          );
        } catch (error) {
          if (readerWindow && !readerWindow.closed) readerWindow.close();
          mostrarError(message, error);
        } finally {
          button.disabled = false;
          button.textContent = originalText;
        }
      }

      async function descargarArchivo(button: HTMLButtonElement) {
        const productId = button.dataset.productId || "";
        const filename = button.dataset.filename || `${productId}.pdf`;
        const message = obtenerMensaje(button);

        if (!productId || !message) return;

        const originalText = button.textContent || "Descargar PDF";

        button.disabled = true;
        button.textContent = "Preparando descarga...";
        limpiarMensaje(message);

        try {
          const signedUrl = await obtenerEnlace(productId);
          const fileResponse = await fetch(signedUrl);

          if (!fileResponse.ok) {
            throw new Error("No fue posible obtener el archivo PDF.");
          }

          const fileBlob = await fileResponse.blob();
          const objectUrl = URL.createObjectURL(fileBlob);
          const link = document.createElement("a");

          link.href = objectUrl;
          link.download = filename;
          link.style.display = "none";

          document.body.appendChild(link);
          link.click();
          link.remove();

          window.setTimeout(() => {
            URL.revokeObjectURL(objectUrl);
          }, 1000);

          mostrarMensaje(
            message,
            "La descarga comenzó correctamente.",
            "success"
          );
        } catch (error) {
          console.error("Error descargando ebook:", error);
          mostrarError(message, error);
        } finally {
          button.disabled = false;
          button.textContent = originalText;
        }
      }

      function obtenerMensaje(button: HTMLButtonElement) {
        const card = button.closest(".book-card");
        return card?.querySelector<HTMLElement>(".action-message") || null;
      }

      function limpiarMensaje(message: HTMLElement) {
        message.textContent = "";
        message.className = "action-message";
      }

      function mostrarMensaje(
        message: HTMLElement,
        text: string,
        type: "success" | "error"
      ) {
        message.textContent = text;
        message.className = `action-message ${type}`;
      }

      function mostrarError(message: HTMLElement, error: unknown) {
        console.error(error);

        mostrarMensaje(
          message,
          getErrorMessage(error, "No fue posible completar la operación."),
          "error"
        );
      }

      function getErrorMessage(error: unknown, fallback: string) {
        if (error instanceof Error) return error.message;

        if (
          typeof error === "object" &&
          error !== null &&
          "message" in error &&
          typeof (error as { message?: unknown }).message === "string"
        ) {
          return (error as { message: string }).message;
        }

        return fallback;
      }

      searchInput?.addEventListener("input", renderFilteredBooks);
      categoryFilter?.addEventListener("change", renderFilteredBooks);

      logoutButton?.addEventListener("click", async () => {
        logoutButton.disabled = true;
        logoutButton.textContent = "Cerrando sesión...";

        await supabase.auth.signOut();
        window.location.href = "/";
      });

      function mostrarMensajeGeneral(
        text: string,
        type: "success" | "error"
      ) {
        if (!generalMessage) return;

        generalMessage.hidden = false;
        generalMessage.textContent = text;
        generalMessage.className = `general-message ${type}`;
      }

      function escapeHtml(value: unknown) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      iniciarBiblioteca();
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter,
      system-ui,
      sans-serif;

    color: #17324d;
    background: #f4f8fa;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;

    background:
      radial-gradient(
        circle at top left,
        rgb(15 125 131 / 10%),
        transparent 30rem
      ),
      linear-gradient(
        135deg,
        #f3fbfa,
        #f8fafc
      );
  }

  button,
  input,
  select {
    font: inherit;
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 30;

    background:
      rgb(255 255 255 / 94%);

    border-bottom:
      1px solid #dfe9ef;

    backdrop-filter:
      blur(15px);
  }

  .topbar-inner {
    display: flex;
    width: min(1180px, 92%);
    min-height: 74px;
    margin: auto;

    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;

    color: inherit;
    text-decoration: none;
  }

  .brand-copy {
    display: grid;
  }

  .brand-copy strong {
    line-height: 1;
  }

  .brand-copy small {
    margin-top: 0.25rem;

    color: #60758a;

    font-size: 0.65rem;
    font-weight: 850;

    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .logo {
    display: grid;

    width: 46px;
    height: 46px;

    place-items: center;

    color: #fff;

    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #17324d
      );

    border-radius: 13px;

    font-weight: 900;
  }

  .main-nav {
    display: flex;
    gap: 1.5rem;
  }

  .main-nav a {
    position: relative;
    padding: 0.5rem 0;

    color: #51687d;

    font-weight: 750;
    text-decoration: none;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: #0f7d83;
  }

  .main-nav a.active::after {
    position: absolute;

    right: 0;
    bottom: 0;
    left: 0;

    height: 2px;

    background: #0f7d83;

    content: "";
  }

  .logout-button,
  .primary-link {
    display: inline-flex;

    min-height: 44px;

    padding:
      0.75rem
      1rem;

    align-items: center;
    justify-content: center;

    color: #fff;
    background: #17324d;

    border: 0;
    border-radius: 10px;

    font-weight: 800;
    text-decoration: none;

    cursor: pointer;
  }

  .logout-button:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  .library-shell {
    width: min(1180px, 92%);
    margin: auto;

    padding:
      4rem
      0
      6rem;
  }

  .hero {
    display: flex;

    align-items: flex-end;
    justify-content: space-between;

    gap: 2rem;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    color: #0f7d83;

    font-size: 0.78rem;
    font-weight: 850;

    letter-spacing: 0.18em;
  }

  h1 {
    margin: 1rem 0;

    font:
      clamp(3rem, 7vw, 5.2rem) / 1
      Georgia,
      serif;
  }

  #welcome {
    margin: 0;

    color: #60758a;

    font-size: 1.05rem;
    line-height: 1.7;
  }

  .library-counter {
    display: grid;

    min-width: 175px;

    padding: 1.25rem;

    text-align: center;

    background: #fff;

    border:
      1px solid
      #dfe9ef;

    border-radius: 18px;

    box-shadow:
      0 15px 40px
      rgb(23 50 77 / 8%);
  }

  .library-counter strong {
    color: #0f7d83;
    font-size: 2.2rem;
  }

  .library-counter span {
    color: #60758a;

    font-size: 0.85rem;
    font-weight: 750;
  }

  .toolbar {
    display: grid;

    grid-template-columns:
      minmax(250px, 1fr)
      minmax(210px, 280px);

    gap: 1rem;

    margin-top: 3rem;
    padding: 1rem;

    background: #fff;

    border:
      1px solid
      #dfe9ef;

    border-radius: 18px;

    box-shadow:
      0 15px 40px
      rgb(23 50 77 / 7%);
  }

  .search-field {
    display: flex;

    min-height: 50px;

    align-items: center;
    gap: 0.65rem;

    padding: 0 1rem;

    border:
      1px solid
      #cddbe5;

    border-radius: 11px;
  }

  .search-icon {
    color: #0f7d83;
    font-size: 1.4rem;
  }

  .search-field input {
    width: 100%;
    min-width: 0;

    color: #17324d;
    background: transparent;

    border: 0;
    outline: none;
  }

  .category-field {
    display: grid;
    gap: 0.35rem;
  }

  .category-field span {
    color: #60758a;

    font-size: 0.7rem;
    font-weight: 850;

    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .category-field select {
    min-height: 50px;

    padding:
      0
      0.8rem;

    color: #17324d;
    background: #fff;

    border:
      1px solid
      #cddbe5;

    border-radius: 11px;
  }

  .books-grid {
    display: grid;

    grid-template-columns:
      repeat(
        auto-fit,
        minmax(280px, 320px)
      );

    justify-content: center;

    gap: 2rem;

    margin-top: 2rem;
  }

  .book-card {
    display: flex;

    width: 100%;
    max-width: 320px;

    flex-direction: column;

    overflow: hidden;

    background: #fff;

    border:
      1px solid
      #dfe9ef;

    border-radius: 22px;

    box-shadow:
      0 18px 48px
      rgb(23 50 77 / 10%);

    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .book-card:hover {
    transform:
      translateY(-6px);

    box-shadow:
      0 25px 60px
      rgb(23 50 77 / 15%);
  }

  .cover-panel {
    display: flex;

    min-height: 390px;

    padding: 28px;

    align-items: center;
    justify-content: center;

    background:
      linear-gradient(
        135deg,
        #edf7f6,
        #f7f3ed
      );
  }

  .book-cover {
    display: block;

    width: auto;
    max-width: 220px;
    height: 330px;

    object-fit: contain;

    border-radius: 8px;

