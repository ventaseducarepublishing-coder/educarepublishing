<!doctype html><html lang="es"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Mi biblioteca | Educare Publishing</title></head><body>
<main class="library"><header><a class="brand" href="/"><span class="logo">EP</span>Educare Publishing</a><button id="logout">Cerrar sesión</button></header><section><span class="eyebrow">MI CUENTA</span><h1>Mi biblioteca</h1><p id="welcome">Cargando...</p></section><div id="books" class="books"></div><section id="empty" class="empty" hidden><h2>Aún no tienes ebooks aprobados</h2><p>Cuando Mercado Pago confirme tu compra, aparecerá aquí.</p><a class="button" href="/#ebooks">Explorar ebooks</a></section></main>
<script>import { supabase } from "../lib/supabase";const {data:{session}}=await supabase.auth.getSession();if(!session){window.location.href="/login"}else{const welcome=document.querySelector("#welcome");const books=document.querySelector("#books");const empty=document.querySelector("#empty");welcome.textContent=`Hola, ${session.user.user_metadata?.full_name||session.user.email}.`;const {data,error}=await supabase.from("purchases").select("id,product_id,product_title,amount,currency,status,created_at").eq("status","approved").order("created_at",{ascending:false});if(error){welcome.textContent="No fue posible cargar la biblioteca."}else if(!data?.length){empty.hidden=false}else{books.innerHTML=data.map(p=>`<article class="book-card"><div class="book-icon">📘</div><small>COMPRA APROBADA</small><h2>${escapeHtml(p.product_title)}</h2><p>${new Intl.NumberFormat("es-CL",{style:"currency",currency:p.currency||"CLP",maximumFractionDigits:0}).format(Number(p.amount||0))}</p></article>`).join("")}}document.querySelector("#logout")?.addEventListener("click",async()=>{await supabase.auth.signOut();window.location.href="/"});function escapeHtml(v){return String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;")}</script></body></html>
<style>:root{font-family:Inter,system-ui,sans-serif;color:#17324d;background:#f4f8fa}*{box-sizing:border-box}body{margin:0}.library{width:min(1120px,92%);margin:auto;padding:2rem 0 5rem}header{display:flex;justify-content:space-between;align-items:center;gap:2rem;margin-bottom:5rem}.brand{display:inline-flex;align-items:center;gap:.75rem;font-weight:800}.logo{display:grid;width:44px;height:44px;place-items:center;color:#fff;background:#0f7d83;border-radius:12px}button,.button{padding:.8rem 1rem;color:#fff;background:#17324d;border:0;border-radius:10px;font:inherit;font-weight:800;text-decoration:none}.eyebrow{color:#0f7d83;font-size:.75rem;font-weight:800;letter-spacing:.17em}h1{font:clamp(3rem,7vw,5rem)/1 Georgia,serif}.books{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-top:3rem}.book-card,.empty{padding:2rem;background:#fff;border:1px solid #dfe9ef;border-radius:20px;box-shadow:0 18px 50px rgb(23 50 77 / 8%)}.book-icon{font-size:3rem}.empty{text-align:center;margin-top:3rem}@media(max-width:760px){header{align-items:flex-start;flex-direction:column}.books{grid-template-columns:1fr}}</style>
