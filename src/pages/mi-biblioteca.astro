<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <title>Mi biblioteca | Educare Publishing</title>
  </head>

  <body>
    <main class="library">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="logo">EP</span>
          <span>Educare Publishing</span>
        </a>

        <div class="header-actions">
          <a class="home-link" href="/">
            Volver a la tienda
          </a>

          <button
            id="logout"
            class="logout-button"
            type="button"
          >
            Cerrar sesión
          </button>
        </div>
      </header>

      <section class="intro">
        <span class="eyebrow">MI CUENTA</span>
        <h1>Mi biblioteca</h1>
        <p id="welcome">Cargando...</p>
      </section>

      <div
        id="general-message"
        class="general-message"
        hidden
      ></div>

      <section
        id="books"
        class="books"
        aria-live="polite"
      ></section>

      <section
        id="empty"
        class="empty"
        hidden
      >
        <div class="empty-icon">📚</div>
        <h2>Aún no tienes ebooks aprobados</h2>
        <p>
          Cuando Mercado Pago confirme tu compra,
          el ebook aparecerá automáticamente aquí.
        </p>
        <a class="button" href="/#ebooks">
          Explorar ebooks
        </a>
      </section>
    </main>

    <script>
      import { supabase } from "../lib/supabase";

      const covers = {
        recien_nacido:
          "/portadas/primer-ano-bebe.png",
        sopas_caseras:
          "/portadas/sopas-del-mundo.png",
        lactancia_materna:
          "/portadas/lactancia-materna.png",
      };

      const welcome =
        document.querySelector("#welcome");
      const books =
        document.querySelector("#books");
      const empty =
        document.querySelector("#empty");
      const generalMessage =
        document.querySelector("#general-message");
      const logoutButton =
        document.querySelector("#logout");

      iniciarBiblioteca();

      async function iniciarBiblioteca() {
        try {
          const {
            data: { session },
            error: sessionError,
          } = await supabase.auth.getSession();

          if (sessionError) throw sessionError;

          if (!session) {
            window.location.href = "/login";
            return;
          }

          const displayName =
            session.user.user_metadata?.full_name ||
            session.user.email ||
            "lector";

          if (welcome) {
            welcome.textContent =
              `Hola, ${displayName}. Estos son tus ebooks disponibles.`;
          }

          const { data, error } =
            await supabase
              .from("purchases")
              .select(
                `
                  id,
                  user_id,
                  product_id,
                  product_title,
                  amount,
                  currency,
                  status,
                  approved_at,
                  created_at
                `
              )
              .eq("user_id", session.user.id)
              .eq("status", "approved")
              .order("created_at", {
                ascending: false,
              });

          if (error) throw error;

          if (!data?.length) {
            if (empty) empty.hidden = false;
            return;
          }

          if (empty) empty.hidden = true;

          renderBooks(
            data,
            session.access_token
          );
        } catch (error) {
          console.error(
            "Error cargando biblioteca:",
            error
          );

          if (welcome) {
            welcome.textContent =
              "No fue posible cargar tu biblioteca.";
          }

          mostrarMensajeGeneral(
            error instanceof Error
              ? error.message
              : "Ocurrió un error inesperado.",
            "error"
          );
        }
      }

      function renderBooks(
        purchases,
        accessToken
      ) {
        if (!books) return;

        books.innerHTML = purchases
          .map((purchase) => {
            const cover =
              covers[purchase.product_id] ||
              "/favicon.svg";

            const purchaseDate =
              purchase.approved_at ||
              purchase.created_at;

            const formattedDate =
              purchaseDate
                ? new Intl.DateTimeFormat(
                    "es-CL",
                    {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    }
                  ).format(
                    new Date(purchaseDate)
                  )
                : "Fecha no disponible";

            return `
              <article class="book-card">
                <div class="cover-wrapper">
                  <img
                    class="book-cover"
                    src="${escapeHtml(cover)}"
                    alt="Portada de ${escapeHtml(
                      purchase.product_title
                    )}"
                    loading="lazy"
                  />
                </div>

                <div class="book-content">
                  <span class="status-badge">
                    Compra aprobada
                  </span>

                  <h2>
                    ${escapeHtml(
                      purchase.product_title
                    )}
                  </h2>

                  <p class="purchase-date">
                    Disponible desde
                    ${escapeHtml(formattedDate)}
                  </p>

                  <button
                    class="download-button"
                    type="button"
                    data-product-id="${escapeHtml(
                      purchase.product_id
                    )}"
                  >
                    Descargar ebook
                  </button>

                  <p
                    class="download-message"
                    aria-live="polite"
                  ></p>
                </div>
              </article>
            `;
          })
          .join("");

        document
          .querySelectorAll(".download-button")
          .forEach((button) => {
            button.addEventListener(
              "click",
              async () => {
                await descargarEbook(
                  button,
                  accessToken
                );
              }
            );
          });
      }

      async function descargarEbook(
        button,
        accessToken
      ) {
        const productId =
          button.dataset.productId || "";

        const card =
          button.closest(".book-card");

        const message =
          card?.querySelector(
            ".download-message"
          );

        if (!productId || !message) return;

        button.disabled = true;
        button.textContent =
          "Preparando descarga...";

        message.textContent = "";
        message.className =
          "download-message";

        try {
          const response = await fetch(
            "/api/download",
            {
              method: "POST",
              headers: {
                "Content-Type":
                  "application/json",
                Authorization:
                  `Bearer ${accessToken}`,
              },
              body: JSON.stringify({
                productId,
              }),
            }
          );

          const result =
            await response.json();

          if (!response.ok) {
            throw new Error(
              result.error ||
              "No fue posible descargar el ebook."
            );
          }

          if (!result.url) {
            throw new Error(
              "El servidor no entregó el enlace de descarga."
            );
          }

          message.textContent =
            "Descarga autorizada. Abriendo ebook…";
          message.classList.add("success");

          const link =
            document.createElement("a");

          link.href = result.url;
          link.target = "_blank";
          link.rel =
            "noopener noreferrer";

          document.body.appendChild(link);
          link.click();
          link.remove();
        } catch (error) {
          console.error(
            "Error descargando ebook:",
            error
          );

          message.textContent =
            error instanceof Error
              ? error.message
              : "No fue posible descargar el ebook.";

          message.classList.add("error");
        } finally {
          button.disabled = false;
          button.textContent =
            "Descargar ebook";
        }
      }

      logoutButton?.addEventListener(
        "click",
        async () => {
          logoutButton.disabled = true;
          logoutButton.textContent =
            "Cerrando sesión...";

          await supabase.auth.signOut();
          window.location.href = "/";
        }
      );

      function mostrarMensajeGeneral(
        text,
        type
      ) {
        if (!generalMessage) return;

        generalMessage.hidden = false;
        generalMessage.textContent = text;
        generalMessage.className =
          `general-message ${type}`;
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }
    </script>
  </body>
</html>

<style>
  :root {
    font-family:
      Inter,
      system-ui,
      sans-serif;
    color: #17324d;
    background: #f4f8fa;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(
        135deg,
        #f3fbfa,
        #f8fafc
      );
  }

  .library {
    width: min(1180px, 92%);
    margin: 0 auto;
    padding: 2rem 0 5rem;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: inherit;
    font-weight: 800;
    text-decoration: none;
  }

  .logo {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    color: #fff;
    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #17324d
      );
    border-radius: 13px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .home-link {
    color: #17324d;
    font-weight: 750;
    text-decoration: none;
  }

  button,
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.85rem 1.1rem;
    color: #fff;
    background: #17324d;
    border: 0;
    border-radius: 11px;
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  button:hover,
  .button:hover {
    transform: translateY(-1px);
  }

  button:disabled {
    opacity: 0.65;
    cursor: wait;
    transform: none;
  }

  .intro {
    max-width: 780px;
  }

  .eyebrow {
    color: #0f7d83;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 1rem 0;
    font:
      clamp(3rem, 7vw, 5rem) / 1
      Georgia,
      serif;
  }

  #welcome {
    color: #60758a;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .books {
    display: grid;
    grid-template-columns:
      repeat(
        auto-fit,
        minmax(280px, 320px)
      );
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  .book-card {
    display: flex;
    width: 100%;
    max-width: 320px;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
    border: 1px solid #dfe9ef;
    border-radius: 20px;
    box-shadow:
      0 14px 38px
      rgb(23 50 77 / 10%);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .book-card:hover {
    transform: translateY(-5px);
    box-shadow:
      0 20px 48px
      rgb(23 50 77 / 14%);
  }

  .cover-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 390px;
    padding: 28px;
    background:
      linear-gradient(
        135deg,
        #edf7f6,
        #f7f3ed
      );
  }

  .book-cover {
    display: block;
    width: auto;
    max-width: 220px;
    height: 330px;
    object-fit: contain;
    border-radius: 8px;
    box-shadow:
      0 12px 30px
      rgb(23 50 77 / 18%);
  }

  .book-content {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.5rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    padding:
      0.4rem
      0.65rem;
    color: #08765c;
    background: #eaf8f2;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .status-badge::before {
    content: "✓";
    margin-right: 0.35rem;
  }

  .book-card h2 {
    margin:
      1rem 0
      0.55rem;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .purchase-date {
    margin:
      0 0
      1.5rem;
    color: #60758a;
    line-height: 1.6;
  }

  .download-button {
    width: 100%;
    margin-top: auto;
    background: #0f7d83;
  }

  .download-message {
    min-height: 22px;
    margin:
      0.8rem 0
      0;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .download-message.success,
  .general-message.success {
    color: #08765c;
  }

  .download-message.error,
  .general-message.error {
    color: #b02a37;
  }

  .general-message {
    margin-top: 2rem;
    padding: 1rem;
    background: #fff;
    border: 1px solid #dfe9ef;
    border-radius: 12px;
  }

  .empty {
    margin-top: 3rem;
    padding: 3rem 2rem;
    text-align: center;
    background: #fff;
    border: 1px solid #dfe9ef;
    border-radius: 22px;
    box-shadow:
      0 20px 55px
      rgb(23 50 77 / 8%);
  }

  .empty-icon {
    font-size: 3.4rem;
  }

  @media (max-width: 650px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 3rem;
    }

    .header-actions {
      width: 100%;
      justify-content: space-between;
    }

    .books {
      grid-template-columns: 1fr;
    }

    .book-card {
      max-width: 100%;
    }

    .cover-wrapper {
      min-height: 350px;
    }

    .book-cover {
      max-width: 200px;
      height: 300px;
    }
  }
</style>
