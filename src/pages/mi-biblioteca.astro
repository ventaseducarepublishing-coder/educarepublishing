---
/*
 * Biblioteca personal de Educare Publishing.
 * Las tarjetas se generan con JavaScript, por eso los estilos usan is:global.
 */
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <title>Mi biblioteca | Educare Publishing</title>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <span class="logo">EP</span>
          <span>Educare Publishing</span>
        </a>

        <nav class="nav">
          <a href="/">Inicio</a>
          <a href="/#ebooks">Ebooks</a>
          <a class="active" href="/mi-biblioteca">
            Mi biblioteca
          </a>
        </nav>

        <button
          id="logout"
          class="logout-button"
          type="button"
        >
          Cerrar sesión
        </button>
      </div>
    </header>

    <main class="library">
      <section class="intro">
        <span class="eyebrow">MI CUENTA</span>
        <h1>Mi biblioteca</h1>
        <p id="welcome">Cargando...</p>
      </section>

      <section class="toolbar">
        <input
          id="search"
          type="search"
          placeholder="Buscar ebook"
          autocomplete="off"
        />

        <select id="category-filter">
          <option value="all">
            Todas las categorías
          </option>
        </select>
      </section>

      <div
        id="general-message"
        class="general-message"
        hidden
      ></div>

      <section
        id="books"
        class="books"
        aria-live="polite"
      ></section>

      <section
        id="no-results"
        class="empty"
        hidden
      >
        <h2>No encontramos resultados</h2>
        <p>Prueba con otro título o categoría.</p>
      </section>

      <section
        id="empty"
        class="empty"
        hidden
      >
        <h2>Aún no tienes ebooks aprobados</h2>
        <p>
          Cuando Mercado Pago confirme tu compra,
          el ebook aparecerá aquí.
        </p>

        <a class="primary-link" href="/#ebooks">
          Explorar ebooks
        </a>
      </section>
    </main>

    <script>
      import { supabase } from "../lib/supabase";

      const catalog = {
        recien_nacido: {
          cover: "/portadas/primer-ano-bebe.png",
          author: "Andrea Carolina Reyes Hernández",
          category: "Salud y familia",
        },

        sopas_caseras: {
          cover: "/portadas/sopas-del-mundo.png",
          author: "Educare Publishing",
          category: "Cocina",
        },

        lactancia_materna: {
          cover: "/portadas/lactancia-materna.png",
          author: "Andrea Carolina Reyes Hernández",
          category: "Maternidad",
        },
      };

      const welcome =
        document.querySelector("#welcome");
      const books =
        document.querySelector("#books");
      const empty =
        document.querySelector("#empty");
      const noResults =
        document.querySelector("#no-results");
      const generalMessage =
        document.querySelector("#general-message");
      const logoutButton =
        document.querySelector("#logout");
      const searchInput =
        document.querySelector("#search");
      const categoryFilter =
        document.querySelector("#category-filter");

      let purchases = [];
      let accessToken = "";

      iniciarBiblioteca();

      async function iniciarBiblioteca() {
        try {
          const {
            data: { session },
            error: sessionError,
          } = await supabase.auth.getSession();

          if (sessionError) {
            throw sessionError;
          }

          if (!session) {
            window.location.href = "/login";
            return;
          }

          accessToken = session.access_token;

          const displayName =
            session.user.user_metadata?.full_name ||
            session.user.email ||
            "lector";

          if (welcome) {
            welcome.textContent =
              `Hola, ${displayName}. Estos son tus ebooks disponibles.`;
          }

          const { data, error } =
            await supabase
              .from("purchases")
              .select(
                `
                  id,
                  user_id,
                  product_id,
                  product_title,
                  status,
                  approved_at,
                  created_at
                `
              )
              .eq("user_id", session.user.id)
              .eq("status", "approved")
              .order("created_at", {
                ascending: false,
              });

          if (error) {
            throw error;
          }

          purchases = Array.isArray(data)
            ? data
            : [];

          if (!purchases.length) {
            if (empty) {
              empty.hidden = false;
            }
            return;
          }

          cargarCategorias();
          renderFilteredBooks();
        } catch (error) {
          console.error(
            "Error cargando biblioteca:",
            error
          );

          if (welcome) {
            welcome.textContent =
              "No fue posible cargar tu biblioteca.";
          }

          mostrarMensajeGeneral(
            error instanceof Error
              ? error.message
              : "Ocurrió un error inesperado."
          );
        }
      }

      function cargarCategorias() {
        if (!categoryFilter) return;

        const categories = [
          ...new Set(
            purchases.map((purchase) => {
              return (
                catalog[purchase.product_id]
                  ?.category ||
                "General"
              );
            })
          ),
        ];

        categoryFilter.innerHTML =
          `<option value="all">Todas las categorías</option>` +
          categories
            .map((category) => {
              return `
                <option value="${escapeHtml(category)}">
                  ${escapeHtml(category)}
                </option>
              `;
            })
            .join("");
      }

      function renderFilteredBooks() {
        const query =
          searchInput?.value
            .trim()
            .toLocaleLowerCase("es") || "";

        const selectedCategory =
          categoryFilter?.value || "all";

        const filtered =
          purchases.filter((purchase) => {
            const metadata =
              catalog[purchase.product_id] ||
              {};

            const title =
              String(
                purchase.product_title || ""
              ).toLocaleLowerCase("es");

            const category =
              String(
                metadata.category || "General"
              );

            const matchesSearch =
              !query ||
              title.includes(query) ||
              category
                .toLocaleLowerCase("es")
                .includes(query);

            const matchesCategory =
              selectedCategory === "all" ||
              category === selectedCategory;

            return (
              matchesSearch &&
              matchesCategory
            );
          });

        if (noResults) {
          noResults.hidden =
            filtered.length > 0;
        }

        renderBooks(filtered);
      }

      function renderBooks(items) {
        if (!books) return;

        books.innerHTML = items
          .map((purchase) => {
            const metadata =
              catalog[purchase.product_id] ||
              {};

            const cover =
              metadata.cover ||
              "/favicon.svg";

            const author =
              metadata.author ||
              "Educare Publishing";

            const category =
              metadata.category ||
              "General";

            const purchaseDate =
              purchase.approved_at ||
              purchase.created_at;

            const formattedDate =
              purchaseDate
                ? new Intl.DateTimeFormat(
                    "es-CL",
                    {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    }
                  ).format(
                    new Date(purchaseDate)
                  )
                : "Fecha no disponible";

            return `
              <article class="book-card">
                <div class="cover-wrapper">
                  <img
                    class="book-cover"
                    src="${escapeHtml(cover)}"
                    alt="Portada de ${escapeHtml(
                      purchase.product_title
                    )}"
                  />
                </div>

                <div class="book-content">
                  <div class="labels">
                    <span class="status-badge">
                      Compra aprobada
                    </span>

                    <span class="category-badge">
                      ${escapeHtml(category)}
                    </span>
                  </div>

                  <h2>
                    ${escapeHtml(
                      purchase.product_title
                    )}
                  </h2>

                  <p class="author">
                    ${escapeHtml(author)}
                  </p>

                  <p class="purchase-date">
                    Disponible desde
                    ${escapeHtml(formattedDate)}
                  </p>

                  <div class="book-actions">
                    <button
                      class="read-button"
                      type="button"
                      data-product-id="${escapeHtml(
                        purchase.product_id
                      )}"
                    >
                      Leer online
                    </button>

                    <button
                      class="download-button"
                      type="button"
                      data-product-id="${escapeHtml(
                        purchase.product_id
                      )}"
                    >
                      Descargar PDF
                    </button>
                  </div>

                  <p
                    class="download-message"
                    aria-live="polite"
                  ></p>
                </div>
              </article>
            `;
          })
          .join("");

        conectarBotones();
      }

      function conectarBotones() {
        document
          .querySelectorAll(".read-button")
          .forEach((button) => {
            button.addEventListener(
              "click",
              async () => {
                await abrirEbook(
                  button,
                  false
                );
              }
            );
          });

        document
          .querySelectorAll(".download-button")
          .forEach((button) => {
            button.addEventListener(
              "click",
              async () => {
                await abrirEbook(
                  button,
                  true
                );
              }
            );
          });
      }

      async function abrirEbook(
        button,
        forceDownload
      ) {
        const productId =
          button.dataset.productId || "";

        const card =
          button.closest(".book-card");

        const message =
          card?.querySelector(
            ".download-message"
          );

        if (!productId || !message) {
          return;
        }

        const originalText =
          button.textContent;

        button.disabled = true;
        button.textContent =
          forceDownload
            ? "Preparando descarga..."
            : "Abriendo...";

        message.textContent = "";
        message.className =
          "download-message";

        try {
          const response = await fetch(
            "/api/download",
            {
              method: "POST",
              headers: {
                "Content-Type":
                  "application/json",
                Authorization:
                  `Bearer ${accessToken}`,
              },
              body: JSON.stringify({
                productId,
              }),
            }
          );

          const result =
            await response.json();

          if (!response.ok) {
            throw new Error(
              result.error ||
              "No fue posible abrir el ebook."
            );
          }

          if (!result.url) {
            throw new Error(
              "El servidor no entregó el enlace del ebook."
            );
          }

          const link =
            document.createElement("a");

          link.href = result.url;
          link.target = "_blank";
          link.rel =
            "noopener noreferrer";

          if (forceDownload) {
            link.download = "";
          }

          document.body.appendChild(link);
          link.click();
          link.remove();

          message.textContent =
            forceDownload
              ? "Descarga autorizada."
              : "Ebook abierto en una nueva pestaña.";

          message.classList.add("success");
        } catch (error) {
          console.error(
            "Error abriendo ebook:",
            error
          );

          message.textContent =
            error instanceof Error
              ? error.message
              : "No fue posible abrir el ebook.";

          message.classList.add("error");
        } finally {
          button.disabled = false;
          button.textContent =
            originalText;
        }
      }

      searchInput?.addEventListener(
        "input",
        renderFilteredBooks
      );

      categoryFilter?.addEventListener(
        "change",
        renderFilteredBooks
      );

      logoutButton?.addEventListener(
        "click",
        async () => {
          logoutButton.disabled = true;
          logoutButton.textContent =
            "Cerrando sesión...";

          await supabase.auth.signOut();

          window.location.href = "/";
        }
      );

      function mostrarMensajeGeneral(text) {
        if (!generalMessage) return;

        generalMessage.hidden = false;
        generalMessage.textContent = text;
        generalMessage.className =
          "general-message error";
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter,
      system-ui,
      sans-serif;
    color: #17324d;
    background: #f4f8fa;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(
        135deg,
        #f3fbfa,
        #f8fafc
      );
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    background:
      rgb(255 255 255 / 94%);
    border-bottom:
      1px solid #dfe9ef;
    backdrop-filter: blur(14px);
  }

  .topbar-inner {
    display: flex;
    width: min(1180px, 92%);
    min-height: 74px;
    margin: auto;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: inherit;
    font-weight: 800;
    text-decoration: none;
  }

  .logo {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    color: #fff;
    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #17324d
      );
    border-radius: 12px;
  }

  .nav {
    display: flex;
    gap: 1.4rem;
  }

  .nav a {
    color: #51687d;
    font-weight: 700;
    text-decoration: none;
  }

  .nav a.active,
  .nav a:hover {
    color: #0f7d83;
  }

  .logout-button,
  .primary-link {
    display: inline-flex;
    min-height: 44px;
    padding: 0.75rem 1rem;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: #17324d;
    border: 0;
    border-radius: 10px;
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  .library {
    width: min(1180px, 92%);
    margin: auto;
    padding: 4rem 0 6rem;
  }

  .eyebrow {
    color: #0f7d83;
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 1rem 0;
    font:
      clamp(3rem, 7vw, 5rem) / 1
      Georgia,
      serif;
  }

  #welcome {
    margin: 0;
    color: #60758a;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .toolbar {
    display: grid;
    grid-template-columns:
      1fr
      minmax(220px, 280px);
    gap: 1rem;
    margin-top: 3rem;
    padding: 1rem;
    background: #fff;
    border:
      1px solid #dfe9ef;
    border-radius: 16px;
  }

  .toolbar input,
  .toolbar select {
    min-height: 48px;
    padding: 0 1rem;
    color: #17324d;
    background: #fff;
    border:
      1px solid #cddbe5;
    border-radius: 10px;
    font: inherit;
  }

  .books {
    display: grid;
    grid-template-columns:
      repeat(
        auto-fit,
        minmax(280px, 320px)
      );
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .book-card {
    display: flex;
    width: 100%;
    max-width: 320px;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
    border:
      1px solid #dfe9ef;
    border-radius: 22px;
    box-shadow:
      0 18px 48px
      rgb(23 50 77 / 10%);
  }

  .cover-wrapper {
    display: flex;
    min-height: 390px;
    padding: 28px;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(
        135deg,
        #edf7f6,
        #f7f3ed
      );
  }

  .book-cover {
    display: block;
    width: auto;
    max-width: 220px;
    height: 330px;
    object-fit: contain;
    border-radius: 8px;
    box-shadow:
      0 14px 34px
      rgb(23 50 77 / 20%);
  }

  .book-content {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.5rem;
  }

  .labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-badge,
  .category-badge {
    display: inline-flex;
    padding:
      0.38rem
      0.6rem;
    border-radius: 999px;
    font-size: 0.67rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .status-badge {
    color: #08765c;
    background: #eaf8f2;
  }

  .status-badge::before {
    margin-right: 0.3rem;
    content: "✓";
  }

  .category-badge {
    color: #3f6072;
    background: #eef3f6;
  }

  .book-card h2 {
    margin:
      1rem 0
      0.35rem;
    font-size: 1.35rem;
  }

  .author,
  .purchase-date {
    color: #60758a;
    line-height: 1.5;
  }

  .author {
    margin:
      0 0
      0.8rem;
    font-size: 0.92rem;
  }

  .purchase-date {
    margin:
      0 0
      1.4rem;
    font-size: 0.86rem;
  }

  .book-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
    margin-top: auto;
  }

  .read-button,
  .download-button {
    min-height: 46px;
    padding: 0.75rem;
    border-radius: 10px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .read-button {
    color: #0f7d83;
    background: #edf8f7;
    border:
      1px solid #b8ddda;
  }

  .download-button {
    color: #fff;
    background: #0f7d83;
    border:
      1px solid #0f7d83;
  }

  .read-button:disabled,
  .download-button:disabled,
  .logout-button:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  .download-message {
    min-height: 20px;
    margin:
      0.75rem 0
      0;
    font-size: 0.82rem;
  }

  .success {
    color: #08765c;
  }

  .error {
    color: #b02a37;
  }

  .general-message,
  .empty {
    margin-top: 2rem;
    padding: 2rem;
    text-align: center;
    background: #fff;
    border:
      1px solid #dfe9ef;
    border-radius: 18px;
  }

  @media (max-width: 760px) {
    .nav {
      display: none;
    }

    .toolbar {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 650px) {
    .brand span:last-child {
      display: none;
    }

    .books {
      grid-template-columns: 1fr;
    }

    .book-card {
      max-width: 100%;
    }

    .cover-wrapper {
      min-height: 350px;
    }

    .book-cover {
      max-width: 200px;
      height: 300px;
    }

    .book-actions {
      grid-template-columns: 1fr;
    }
  }
</style>
