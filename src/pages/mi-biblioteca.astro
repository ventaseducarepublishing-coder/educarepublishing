---
/*
 * Mi biblioteca — Educare Publishing
 * Versión completa y profesional.
 *
 * Incluye:
 * - Supabase Auth
 * - Compras aprobadas
 * - Buscador y categorías
 * - Lectura online con pestaña de carga
 * - Descarga real mediante Blob
 * - Diseño responsive
 *
 * Los estilos usan is:global porque las tarjetas
 * se crean dinámicamente con JavaScript.
 */
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta
      name="description"
      content="Biblioteca personal de ebooks adquiridos en Educare Publishing."
    />

    <title>Mi biblioteca | Educare Publishing</title>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <span class="logo">EP</span>

          <span class="brand-copy">
            <strong>Educare</strong>
            <small>Publishing</small>
          </span>
        </a>

        <nav
          class="main-nav"
          aria-label="Navegación principal"
        >
          <a href="/">Inicio</a>
          <a href="/#ebooks">Ebooks</a>

          <a
            class="active"
            href="/mi-biblioteca"
          >
            Mi biblioteca
          </a>
        </nav>

        <button
          id="logout"
          class="logout-button"
          type="button"
        >
          Cerrar sesión
        </button>
      </div>
    </header>

    <main class="library-shell">
      <section class="hero">
        <div class="hero-copy">
          <span class="eyebrow">
            MI CUENTA
          </span>

          <h1>Mi biblioteca</h1>

          <p id="welcome">
            Cargando tus ebooks...
          </p>
        </div>

        <div class="library-counter">
          <strong id="book-count">0</strong>
          <span>Ebooks disponibles</span>
        </div>
      </section>

      <section
        class="toolbar"
        aria-label="Herramientas de biblioteca"
      >
        <label class="search-field">
          <span
            class="search-icon"
            aria-hidden="true"
          >
            ⌕
          </span>

          <input
            id="search"
            type="search"
            placeholder="Buscar por título, autor o categoría"
            autocomplete="off"
          />
        </label>

        <label class="category-field">
          <span>Categoría</span>

          <select id="category-filter">
            <option value="all">
              Todas las categorías
            </option>
          </select>
        </label>
      </section>

      <div
        id="general-message"
        class="general-message"
        hidden
      ></div>

      <section
        id="books"
        class="books-grid"
        aria-live="polite"
      ></section>

      <section
        id="no-results"
        class="empty-state"
        hidden
      >
        <span class="empty-icon">🔎</span>

        <h2>No encontramos resultados</h2>

        <p>
          Prueba con otro título, autor o categoría.
        </p>
      </section>

      <section
        id="empty"
        class="empty-state"
        hidden
      >
        <span class="empty-icon">📚</span>

        <h2>
          Aún no tienes ebooks aprobados
        </h2>

        <p>
          Cuando Mercado Pago confirme tu compra,
          el ebook aparecerá automáticamente aquí.
        </p>

        <a
          class="primary-link"
          href="/#ebooks"
        >
          Explorar ebooks
        </a>
      </section>
    </main>

    <script>
      import { supabase } from "../lib/supabase";

      const catalog = {
        recien_nacido: {
          cover:
            "/portadas/primer-ano-bebe.png",

          author:
            "Andrea Carolina Reyes Hernández",

          category:
            "Salud y familia",

          filename:
            "guia-primer-ano-bebe.pdf",
        },

        sopas_caseras: {
          cover:
            "/portadas/sopas-del-mundo.png",

          author:
            "Educare Publishing",

          category:
            "Cocina",

          filename:
            "las-mejores-sopas-del-mundo.pdf",
        },

        lactancia_materna: {
          cover:
            "/portadas/lactancia-materna.png",

          author:
            "Andrea Carolina Reyes Hernández",

          category:
            "Maternidad",

          filename:
            "lactancia-materna.pdf",
        },
      };

      const welcome =
        document.querySelector("#welcome");

      const books =
        document.querySelector("#books");

      const empty =
        document.querySelector("#empty");

      const noResults =
        document.querySelector("#no-results");

      const generalMessage =
        document.querySelector(
          "#general-message"
        );

      const logoutButton =
        document.querySelector("#logout");

      const searchInput =
        document.querySelector("#search");

      const categoryFilter =
        document.querySelector(
          "#category-filter"
        );

      const bookCount =
        document.querySelector("#book-count");

      let purchases = [];
      let accessToken = "";

      iniciarBiblioteca();

      async function iniciarBiblioteca() {
        try {
          const {
            data: { session },
            error: sessionError,
          } = await supabase.auth.getSession();

          if (sessionError) {
            throw sessionError;
          }

          if (!session) {
            window.location.href = "/login";
            return;
          }

          accessToken = session.access_token;

          const displayName =
            session.user.user_metadata
              ?.full_name ||
            session.user.email ||
            "lector";

          if (welcome) {
            welcome.textContent =
              `Hola, ${displayName}. Aquí puedes leer y descargar tus ebooks.`;
          }

          const { data, error } =
            await supabase
              .from("purchases")
              .select(
                `
                  id,
                  user_id,
                  product_id,
                  product_title,
                  status,
                  approved_at,
                  created_at
                `
              )
              .eq(
                "user_id",
                session.user.id
              )
              .eq(
                "status",
                "approved"
              )
              .order(
                "created_at",
                {
                  ascending: false,
                }
              );

          if (error) {
            throw error;
          }

          purchases =
            Array.isArray(data)
              ? data
              : [];

          if (bookCount) {
            bookCount.textContent =
              String(purchases.length);
          }

          if (!purchases.length) {
            if (empty) {
              empty.hidden = false;
            }

            return;
          }

          if (empty) {
            empty.hidden = true;
          }

          cargarCategorias();
          renderFilteredBooks();
        } catch (error) {
          console.error(
            "Error cargando biblioteca:",
            error
          );

          if (welcome) {
            welcome.textContent =
              "No fue posible cargar tu biblioteca.";
          }

          mostrarMensajeGeneral(
            error instanceof Error
              ? error.message
              : "Ocurrió un error inesperado.",
            "error"
          );
        }
      }

      function cargarCategorias() {
        if (!categoryFilter) return;

        const categories = [
          ...new Set(
            purchases.map(
              (purchase) => {
                return (
                  catalog[
                    purchase.product_id
                  ]?.category ||
                  "General"
                );
              }
            )
          ),
        ].sort((a, b) =>
          a.localeCompare(b, "es")
        );

        categoryFilter.innerHTML =
          `
            <option value="all">
              Todas las categorías
            </option>
          ` +
          categories
            .map((category) => {
              return `
                <option
                  value="${escapeHtml(
                    category
                  )}"
                >
                  ${escapeHtml(category)}
                </option>
              `;
            })
            .join("");
      }

      function renderFilteredBooks() {
        const query =
          searchInput?.value
            .trim()
            .toLocaleLowerCase("es") ||
          "";

        const selectedCategory =
          categoryFilter?.value ||
          "all";

        const filtered =
          purchases.filter(
            (purchase) => {
              const metadata =
                catalog[
                  purchase.product_id
                ] || {};

              const title =
                String(
                  purchase.product_title ||
                  ""
                ).toLocaleLowerCase("es");

              const author =
                String(
                  metadata.author || ""
                ).toLocaleLowerCase("es");

              const category =
                String(
                  metadata.category ||
                  "General"
                );

              const matchesSearch =
                !query ||
                title.includes(query) ||
                author.includes(query) ||
                category
                  .toLocaleLowerCase("es")
                  .includes(query);

              const matchesCategory =
                selectedCategory === "all" ||
                category ===
                  selectedCategory;

              return (
                matchesSearch &&
                matchesCategory
              );
            }
          );

        if (noResults) {
          noResults.hidden =
            filtered.length > 0;
        }

        renderBooks(filtered);
      }

      function renderBooks(items) {
        if (!books) return;

        books.innerHTML = items
          .map((purchase) => {
            const metadata =
              catalog[
                purchase.product_id
              ] || {};

            const cover =
              metadata.cover ||
              "/favicon.svg";

            const author =
              metadata.author ||
              "Educare Publishing";

            const category =
              metadata.category ||
              "General";

            const purchaseDate =
              purchase.approved_at ||
              purchase.created_at;

            const formattedDate =
              purchaseDate
                ? new Intl.DateTimeFormat(
                    "es-CL",
                    {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    }
                  ).format(
                    new Date(
                      purchaseDate
                    )
                  )
                : "Fecha no disponible";

            return `
              <article class="book-card">
                <div class="cover-panel">
                  <img
                    class="book-cover"
                    src="${escapeHtml(
                      cover
                    )}"
                    alt="Portada de ${escapeHtml(
                      purchase.product_title
                    )}"
                    loading="lazy"
                  />
                </div>

                <div class="book-content">
                  <div class="badges">
                    <span class="status-badge">
                      Compra verificada
                    </span>

                    <span class="category-badge">
                      ${escapeHtml(
                        category
                      )}
                    </span>
                  </div>

                  <h2>
                    ${escapeHtml(
                      purchase.product_title
                    )}
                  </h2>

                  <p class="book-author">
                    ${escapeHtml(author)}
                  </p>

                  <div class="book-info">
                    <span>
                      Disponible desde
                    </span>

                    <strong>
                      ${escapeHtml(
                        formattedDate
                      )}
                    </strong>
                  </div>

                  <div class="book-actions">
                    <button
                      class="read-button"
                      type="button"
                      data-product-id="${escapeHtml(
                        purchase.product_id
                      )}"
                    >
                      Leer online
                    </button>

                    <button
                      class="download-button"
                      type="button"
                      data-product-id="${escapeHtml(
                        purchase.product_id
                      )}"
                    >
                      Descargar PDF
                    </button>
                  </div>

                  <p
                    class="action-message"
                    aria-live="polite"
                  ></p>
                </div>
              </article>
            `;
          })
          .join("");

        conectarBotones();
      }

      function conectarBotones() {
        document
          .querySelectorAll(
            ".read-button"
          )
          .forEach((button) => {
            button.addEventListener(
              "click",
              async () => {
                await abrirOnline(
                  button
                );
              }
            );
          });

        document
          .querySelectorAll(
            ".download-button"
          )
          .forEach((button) => {
            button.addEventListener(
              "click",
              async () => {
                await descargarArchivo(
                  button
                );
              }
            );
          });
      }

      async function obtenerEnlace(
        productId
      ) {
        const response = await fetch(
          "/api/download",
          {
            method: "POST",

            headers: {
              "Content-Type":
                "application/json",

              Authorization:
                `Bearer ${accessToken}`,
            },

            body: JSON.stringify({
              productId,
            }),
          }
        );

        const result =
          await response.json();

        if (!response.ok) {
          throw new Error(
            result.error ||
            "No fue posible autorizar el ebook."
          );
        }

        if (!result.url) {
          throw new Error(
            "El servidor no entregó el enlace del ebook."
          );
        }

        return result.url;
      }

      async function abrirOnline(
        button
      ) {
        const productId =
          button.dataset.productId ||
          "";

        const message =
          obtenerMensaje(button);

        if (
          !productId ||
          !message
        ) {
          return;
        }

        const originalText =
          button.textContent;

        /*
         * Abrimos la pestaña inmediatamente.
         * Así el navegador no la bloquea
         * como ventana emergente tardía.
         */
        /*
         * Abrimos la pestaña en el clic directo.
         * No usamos "noopener" dentro de window.open porque
         * algunos navegadores devuelven null aunque la pestaña
         * sí se haya creado. Eso provocaba que la biblioteca
         * también navegara al PDF y quedara una pestaña blanca.
         */
        const readerWindow =
          window.open(
            "about:blank",
            "_blank"
          );

        button.disabled = true;
        button.textContent =
          "Abriendo...";

        limpiarMensaje(message);

        try {
          if (!readerWindow) {
            throw new Error(
              "El navegador bloqueó la nueva pestaña. Permite ventanas emergentes para este sitio."
            );
          }

          /*
           * Cortamos la relación con la página original
           * después de obtener una referencia válida.
           */
          readerWindow.opener = null;

          readerWindow.document.title =
            "Preparando ebook";

          readerWindow.document.body.innerHTML = `
            <div style="
              min-height:100vh;
              display:grid;
              place-items:center;
              padding:24px;
              font-family:Arial,sans-serif;
              color:#17324d;
              background:#f4f8fa;
            ">
              <div style="
                max-width:420px;
                text-align:center;
              ">
                <div style="
                  width:54px;
                  height:54px;
                  margin:0 auto 18px;
                  border:5px solid #d8e7e8;
                  border-top-color:#0f7d83;
                  border-radius:50%;
                  animation:spin 1s linear infinite;
                "></div>

                <h2 style="
                  margin:0 0 10px;
                ">
                  Preparando tu ebook...
                </h2>

                <p style="
                  margin:0;
                  color:#60758a;
                  line-height:1.6;
                ">
                  Estamos validando tu compra
                  y generando un acceso seguro.
                </p>
              </div>

              <style>
                @keyframes spin {
                  to {
                    transform:
                      rotate(360deg);
                  }
                }
              </style>
            </div>
          `;

          const url =
            await obtenerEnlace(
              productId
            );

          /*
           * Solo la pestaña nueva navega al PDF.
           * La biblioteca permanece abierta y no se reemplaza.
           */
          readerWindow.location.replace(
            url
          );

          mostrarMensaje(
            message,
            "Ebook abierto en una nueva pestaña.",
            "success"
          );
        } catch (error) {
          if (
            readerWindow &&
            !readerWindow.closed
          ) {
            readerWindow.close();
          }

          mostrarError(
            message,
            error
          );
        } finally {
          button.disabled = false;
          button.textContent =
            originalText;
        }
      }

      async function descargarArchivo(
        button
      ) {
        const productId =
          button.dataset.productId ||
          "";

        const message =
          obtenerMensaje(button);

        if (
          !productId ||
          !message
        ) {
          return;
        }

        const originalText =
          button.textContent;

        button.disabled = true;
        button.textContent =
          "Preparando descarga...";

        limpiarMensaje(message);

        try {
          const signedUrl =
            await obtenerEnlace(
              productId
            );

          const fileResponse =
            await fetch(
              signedUrl
            );

          if (!fileResponse.ok) {
            throw new Error(
              "No fue posible obtener el archivo PDF."
            );
          }

          const fileBlob =
            await fileResponse.blob();

          const objectUrl =
            URL.createObjectURL(
              fileBlob
            );

          const filename =
            catalog[productId]
              ?.filename ||
            `${productId}.pdf`;

          const link =
            document.createElement(
              "a"
            );

          link.href = objectUrl;
          link.download =
            filename;

          link.style.display =
            "none";

          document.body.appendChild(
            link
          );

          link.click();
          link.remove();

          window.setTimeout(() => {
            URL.revokeObjectURL(
              objectUrl
            );
          }, 1000);

          mostrarMensaje(
            message,
            "La descarga comenzó correctamente.",
            "success"
          );
        } catch (error) {
          console.error(
            "Error descargando ebook:",
            error
          );

          mostrarError(
            message,
            error
          );
        } finally {
          button.disabled = false;
          button.textContent =
            originalText;
        }
      }

      function obtenerMensaje(
        button
      ) {
        const card =
          button.closest(
            ".book-card"
          );

        return card?.querySelector(
          ".action-message"
        );
      }

      function limpiarMensaje(
        message
      ) {
        message.textContent = "";
        message.className =
          "action-message";
      }

      function mostrarMensaje(
        message,
        text,
        type
      ) {
        message.textContent =
          text;

        message.className =
          `action-message ${type}`;
      }

      function mostrarError(
        message,
        error
      ) {
        console.error(error);

        mostrarMensaje(
          message,
          error instanceof Error
            ? error.message
            : "No fue posible completar la operación.",
          "error"
        );
      }

      searchInput?.addEventListener(
        "input",
        renderFilteredBooks
      );

      categoryFilter?.addEventListener(
        "change",
        renderFilteredBooks
      );

      logoutButton?.addEventListener(
        "click",
        async () => {
          logoutButton.disabled = true;
          logoutButton.textContent =
            "Cerrando sesión...";

          await supabase.auth.signOut();

          window.location.href = "/";
        }
      );

      function mostrarMensajeGeneral(
        text,
        type
      ) {
        if (!generalMessage) return;

        generalMessage.hidden =
          false;

        generalMessage.textContent =
          text;

        generalMessage.className =
          `general-message ${type}`;
      }

      function escapeHtml(value) {
        return String(
          value ?? ""
        )
          .replaceAll(
            "&",
            "&amp;"
          )
          .replaceAll(
            "<",
            "&lt;"
          )
          .replaceAll(
            ">",
            "&gt;"
          )
          .replaceAll(
            '"',
            "&quot;"
          )
          .replaceAll(
            "'",
            "&#039;"
          );
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter,
      system-ui,
      sans-serif;

    color: #17324d;
    background: #f4f8fa;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;

    background:
      radial-gradient(
        circle at top left,
        rgb(15 125 131 / 10%),
        transparent 30rem
      ),
      linear-gradient(
        135deg,
        #f3fbfa,
        #f8fafc
      );
  }

  button,
  input,
  select {
    font: inherit;
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 30;

    background:
      rgb(255 255 255 / 94%);

    border-bottom:
      1px solid #dfe9ef;

    backdrop-filter:
      blur(15px);
  }

  .topbar-inner {
    display: flex;
    width: min(1180px, 92%);
    min-height: 74px;
    margin: auto;

    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;

    color: inherit;
    text-decoration: none;
  }

  .brand-copy {
    display: grid;
  }

  .brand-copy strong {
    line-height: 1;
  }

  .brand-copy small {
    margin-top: 0.25rem;

    color: #60758a;

    font-size: 0.65rem;
    font-weight: 850;

    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .logo {
    display: grid;

    width: 46px;
    height: 46px;

    place-items: center;

    color: #fff;

    background:
      linear-gradient(
        135deg,
        #0f7d83,
        #17324d
      );

    border-radius: 13px;

    font-weight: 900;
  }

  .main-nav {
    display: flex;
    gap: 1.5rem;
  }

  .main-nav a {
    position: relative;
    padding: 0.5rem 0;

    color: #51687d;

    font-weight: 750;
    text-decoration: none;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: #0f7d83;
  }

  .main-nav a.active::after {
    position: absolute;

    right: 0;
    bottom: 0;
    left: 0;

    height: 2px;

    background: #0f7d83;

    content: "";
  }

  .logout-button,
  .primary-link {
    display: inline-flex;

    min-height: 44px;

    padding:
      0.75rem
      1rem;

    align-items: center;
    justify-content: center;

    color: #fff;
    background: #17324d;

    border: 0;
    border-radius: 10px;

    font-weight: 800;
    text-decoration: none;

    cursor: pointer;
  }

  .logout-button:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  .library-shell {
    width: min(1180px, 92%);
    margin: auto;

    padding:
      4rem
      0
      6rem;
  }

  .hero {
    display: flex;

    align-items: flex-end;
    justify-content: space-between;

    gap: 2rem;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    color: #0f7d83;

    font-size: 0.78rem;
    font-weight: 850;

    letter-spacing: 0.18em;
  }

  h1 {
    margin: 1rem 0;

    font:
      clamp(3rem, 7vw, 5.2rem) / 1
      Georgia,
      serif;
  }

  #welcome {
    margin: 0;

    color: #60758a;

    font-size: 1.05rem;
    line-height: 1.7;
  }

  .library-counter {
    display: grid;

    min-width: 175px;

    padding: 1.25rem;

    text-align: center;

    background: #fff;

    border:
      1px solid
      #dfe9ef;

    border-radius: 18px;

    box-shadow:
      0 15px 40px
      rgb(23 50 77 / 8%);
  }

  .library-counter strong {
    color: #0f7d83;
    font-size: 2.2rem;
  }

  .library-counter span {
    color: #60758a;

    font-size: 0.85rem;
    font-weight: 750;
  }

  .toolbar {
    display: grid;

    grid-template-columns:
      minmax(250px, 1fr)
      minmax(210px, 280px);

    gap: 1rem;

    margin-top: 3rem;
    padding: 1rem;

    background: #fff;

    border:
      1px solid
      #dfe9ef;

    border-radius: 18px;

    box-shadow:
      0 15px 40px
